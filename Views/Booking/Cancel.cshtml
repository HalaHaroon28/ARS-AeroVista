@model AeroVista.Models.Booking

@{
    ViewData["Title"] = "Cancel Reservation";
}

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root { --navy: #0B1C2D; --gold: #C6A75E; --gold-border: rgba(198,167,94,0.22); --muted: #6a7f95; --danger: #ff4d4d; }
    .page-background { position: fixed; inset: 0; z-index: -1; background: linear-gradient(108deg, #0f2841 0%, #0b1c2d 100%); }
    .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(198,167,94,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(198,167,94,0.03) 1px, transparent 1px); background-size: 72px 72px; }
    .payment-container { display: flex; justify-content: center; align-items: center; padding: 100px 20px; min-height: 85vh; }
    .payment-card { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255, 77, 77, 0.3); border-radius: 24px; padding: 40px; width: 100%; max-width: 500px; }
    .summary-box { background: rgba(255, 77, 77, 0.08); border: 1px solid rgba(255, 77, 77, 0.2); border-radius: 12px; padding: 20px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .btn-submit { width: 100%; padding: 16px; border: none; border-radius: 8px; font-family: 'Orbitron'; font-size: 12px; font-weight: 700; text-transform: uppercase; cursor: pointer; background: linear-gradient(135deg, var(--danger) 0%, #b30000 100%); color: white; }
    .form-control { background: rgba(255, 255, 255, 0.05); border: 1px solid var(--gold-border); color: white; border-radius: 8px; padding: 14px; width: 100%; margin-bottom: 20px; }
    .error-alert { background: rgba(255, 77, 77, 0.15); border: 1px solid var(--danger); color: white; padding: 12px; border-radius: 8px; font-size: 11px; font-family: 'Orbitron'; text-align: center; margin-bottom: 20px; }
</style>

<div class="page-background"><div class="hero-grid"></div></div>

<div class="payment-container">
    <div class="payment-card">
        <div class="payment-header" style="text-align: center; margin-bottom: 30px;">
            <h2 style="font-family: 'Orbitron'; color: var(--danger);">Void <span style="color: white">Itinerary</span></h2>
            <p style="color: var(--muted); font-size: 13px;">Confirm reference to initiate cancellation</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="error-alert">VOID FAILED: @TempData["Error"]</div>
        }

        <form asp-action="ViewByReference" method="get" style="display: flex; gap: 8px; margin-bottom: 25px;">
            <input type="text" name="referenceNumber" placeholder="Reference Number..." class="form-control" style="margin-bottom:0;" required />
            <button type="submit" class="btn-submit" style="width: 80px; padding: 0; background: rgba(255,255,255,0.1); border: 1px solid var(--danger);">LOAD</button>
        </form>

        @if (Model != null)
        {
            <div style="border-top: 1px solid rgba(255,77,77,0.2); padding-top: 25px;">
                <p style="color: var(--muted); font-size: 11px; text-align: center; margin-bottom: 15px;">Target: @Model.Flight.FlightNumber | Ref: @(Model.ConfirmationNumber ?? Model.BlockingNumber)</p>
                
                <div class="summary-box">
                    <div>
                        <div style="font-size: 10px; color: var(--danger); font-family: 'Orbitron';">Refund Credit</div>
                        <div style="font-family: 'Orbitron'; font-size: 16px; color: white;">Rs. @((Model.TotalPrice * 0.80m).ToString("N0"))</div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 10px; color: var(--danger); font-family: 'Orbitron';">20% FEE</div>
                    </div>
                </div>

                <form asp-action="ConfirmCancellation" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <label style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 10px; display: block;">Reason for Voids</label>
                    <select name="reason" required class="form-control">
                        <option value="Schedule Conflict">Schedule Conflict</option>
                        <option value="Personal Reasons">Personal Reasons</option>
                        <option value="Other">Other</option>
                    </select>

                    <button type="submit" class="btn-submit">Confirm Void Sequence</button>
                </form>
            </div>
        }
    </div>
</div>