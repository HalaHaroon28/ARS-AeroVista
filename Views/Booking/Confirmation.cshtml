@model AeroVista.Models.Booking

@{
    ViewData["Title"] = "Authorize Payment";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Orbitron:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    body { font-family: 'Plus_Jakarta_Sans', sans-serif; background: #0B1C2D; }
    .aero-gold { color: #C6A75E; }
    .aero-bg-gold { background: #C6A75E; }
    .orbitron { font-family: 'Orbitron', sans-serif; }
</style>

<div class="min-h-screen flex items-center justify-center p-4 bg-[radial-gradient(circle_at_top_right,_#1a3350_0%,_#0b1c2d_100%)]">
    <div class="max-w-4xl w-full bg-white rounded-2xl shadow-2xl overflow-hidden">
        <div class="md:flex">
            
            <div class="md:w-3/5 p-8">
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-gray-800 orbitron uppercase tracking-wider">Secure <span class="aero-gold">Gateway</span></h2>
                    <p class="text-gray-500 mt-2">Enter credit card credentials to authorize your flight manifest.</p>
                </div>
                
                <form asp-action="SubmitPayment" method="post" id="paymentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="flightId" value="@Model.FlightId" />
                    <input type="hidden" name="adults" value="@Model.Adults" />
                    <input type="hidden" name="children" value="@Model.Children" />
                    <input type="hidden" name="travelClass" value="@Model.TravelClass" />
                    <input type="hidden" name="totalPrice" value="@Model.TotalPrice" />

                    <div class="space-y-5">
                        <div>
                            <label class="block text-xs font-bold text-gray-700 mb-1 uppercase tracking-tighter">Card Number</label>
                            <div class="relative">
                                <input type="text" id="cardNumber" name="transactionId" maxlength="19" placeholder="XXXX XXXX XXXX XXXX" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#C6A75E] focus:border-[#C6A75E] transition outline-none" required>
                                <div class="absolute right-3 top-3 flex space-x-2 text-gray-400">
                                    <i class="fa-brands fa-cc-visa text-xl"></i>
                                    <i class="fa-brands fa-cc-mastercard text-xl"></i>
                                </div>
                            </div>
                        </div>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-700 mb-1 uppercase">Expiration</label>
                                <input type="text" placeholder="MM / YY" maxlength="5" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#C6A75E] outline-none transition" required>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-700 mb-1 uppercase">CVC</label>
                                <div class="relative">
                                    <input type="password" maxlength="3" placeholder="***" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#C6A75E] outline-none transition" required>
                                    <div class="absolute right-3 top-3 text-gray-400">
                                        <i class="fa-solid fa-circle-question"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-xs font-bold text-gray-700 mb-1 uppercase">Network Protocol</label>
                            <select name="paymentMethod" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#C6A75E] outline-none transition bg-white" required>
                                <option value="Visa">Visa Credit/Debit</option>
                                <option value="Mastercard">Mastercard</option>
                                <option value="Amex">American Express</option>
                            </select>
                        </div>

                        <div class="pt-4">
                            <button type="submit" class="w-full aero-bg-gold text-white py-4 px-4 rounded-lg hover:bg-[#b39652] transition font-bold orbitron shadow-lg flex items-center justify-center">
                                <span>Pay Rs. @Model.TotalPrice.ToString("N0")</span>
                                <i class="fa-solid fa-lock ml-2 text-sm"></i>
                            </button>
                            <p class="text-[10px] text-center text-gray-400 mt-4 flex items-center justify-center uppercase tracking-widest">
                                <i class="fa-solid fa-shield-halved mr-2 text-green-500"></i>
                                SSL Encrypted Transaction
                            </p>
                        </div>
                    </div>
                </form>
            </div>
            
            <div class="md:w-2/5 bg-gray-50 p-8 border-l border-gray-200">
                <h3 class="text-lg font-bold text-gray-800 mb-6 orbitron uppercase">Manifest <span class="aero-gold">Brief</span></h3>
                
                <div class="space-y-6 mb-8">
                    <div class="flex items-center">
                        <div class="h-10 w-10 rounded-lg bg-[#0B1C2D] flex items-center justify-center shadow-md">
                            <i class="fa-solid fa-plane-departure text-[#C6A75E] text-sm"></i>
                        </div>
                        <div class="ml-4">
                            <p class="text-xs font-bold text-gray-400 uppercase">Flight Route</p>
                            <p class="text-sm font-semibold text-gray-800">@Model.Flight.FromCity.AirportCode → @Model.Flight.ToCity.AirportCode</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="h-10 w-10 rounded-lg bg-gray-200 flex items-center justify-center shadow-sm">
                            <i class="fa-solid fa-user-group text-gray-600 text-sm"></i>
                        </div>
                        <div class="ml-4">
                            <p class="text-xs font-bold text-gray-400 uppercase">Travelers</p>
                            <p class="text-sm font-semibold text-gray-800">@Model.Adults Adults, @Model.Children Children</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="h-10 w-10 rounded-lg bg-gray-200 flex items-center justify-center shadow-sm">
                            <i class="fa-solid fa-crown text-gray-600 text-sm"></i>
                        </div>
                        <div class="ml-4">
                            <p class="text-xs font-bold text-gray-400 uppercase">Service Class</p>
                            <p class="text-sm font-semibold text-gray-800">@Model.TravelClass</p>
                        </div>
                    </div>
                </div>
                
                <div class="border-t border-dashed border-gray-300 pt-6">
                    <div class="flex justify-between mb-3 text-sm text-gray-600">
                        <span>Base Fare</span>
                        <span class="font-medium text-gray-800">Rs. @Model.TotalPrice.ToString("N0")</span>
                    </div>
                    <div class="flex justify-between mb-3 text-sm text-gray-600">
                        <span>Taxes & Surcharges</span>
                        <span class="font-medium text-green-600">Included</span>
                    </div>
                    <div class="flex justify-between pt-4 border-t border-gray-200">
                        <p class="text-base font-bold text-gray-800 orbitron">Total</p>
                        <p class="text-xl font-bold aero-gold orbitron">Rs. @Model.TotalPrice.ToString("N0")</p>
                    </div>
                </div>
                
                <div class="mt-8 flex justify-center space-x-4 opacity-40 grayscale">
                    <i class="fa-brands fa-cc-visa text-2xl"></i>
                    <i class="fa-brands fa-cc-mastercard text-2xl"></i>
                    <i class="fa-brands fa-cc-amex text-2xl"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Requirement #11 - Card Masking Logic
    document.getElementById('cardNumber').addEventListener('input', function (e) {
        let value = e.target.value.replace(/\D/g, '');
        let formattedValue = '';
        for (let i = 0; i < value.length; i++) {
            if (i > 0 && i % 4 === 0) formattedValue += ' ';
            formattedValue += value[i];
        }
        e.target.value = formattedValue;
    });
</script>