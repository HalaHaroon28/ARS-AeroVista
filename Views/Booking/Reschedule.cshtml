@model AeroVista.Models.Booking

@{
    ViewData["Title"] = "Modify Flight";
}

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root { --navy: #0B1C2D; --gold: #C6A75E; --gold-dim: rgba(198,167,94,0.12); --gold-border: rgba(198,167,94,0.22); --muted: #6a7f95; --danger: #ff4d4d; }
    .page-background { position: fixed; inset: 0; z-index: -1; background: linear-gradient(108deg, #0f2841 0%, #0b1c2d 100%); }
    .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(198,167,94,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(198,167,94,0.03) 1px, transparent 1px); background-size: 72px 72px; }
    .payment-container { display: flex; justify-content: center; align-items: center; padding: 100px 20px; min-height: 85vh; }
    .payment-card { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid var(--gold-border); border-radius: 24px; padding: 40px; width: 100%; max-width: 500px; }
    .form-group label { display: block; font-size: 11px; text-transform: uppercase; color: var(--gold); letter-spacing: 1px; margin-bottom: 10px; font-family: 'Orbitron'; }
    .form-control { background: rgba(255,255,255,0.05); border: 1px solid var(--gold-border); color: white; border-radius: 8px; padding: 14px; width: 100%; outline: none; }
    .btn-submit { width: 100%; padding: 16px; border: none; border-radius: 8px; font-family: 'Orbitron'; font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; transition: 0.3s; background: linear-gradient(135deg, var(--gold) 0%, #d9be80 100%); color: var(--navy); }
    .error-alert { background: rgba(255, 77, 77, 0.15); border: 1px solid var(--danger); color: white; padding: 12px; border-radius: 8px; font-size: 11px; font-family: 'Orbitron'; text-align: center; margin-bottom: 20px; }
</style>

<div class="page-background"><div class="hero-grid"></div></div>

<div class="payment-container">
    <div class="payment-card">
        <div class="payment-header" style="text-align: center; margin-bottom: 30px;">
            <h2 style="font-family: 'Orbitron'; color: white;">Modify <span style="color: var(--gold)">Voyage</span></h2>
            <p style="color: var(--muted); font-size: 13px;">Enter reference to adjust departure</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="error-alert">REFERENCE ERROR: @TempData["Error"]</div>
        }

        <form asp-action="ViewByReference" method="get" style="display: flex; gap: 8px; margin-bottom: 25px;">
            <input type="text" name="referenceNumber" placeholder="Reference Number..." class="form-control" style="font-size: 11px; padding: 8px;" required />
            <button type="submit" class="btn-submit" style="width: 80px; padding: 0; font-size: 10px; background: rgba(255,255,255,0.1); color: white; border: 1px solid var(--gold-border);">LOAD</button>
        </form>

        @if (Model != null)
        {
            <div style="border-top: 1px solid var(--gold-border); padding-top: 25px;">
                <p style="color: var(--muted); font-size: 11px; text-align: center;">Ref: @(Model.ConfirmationNumber ?? Model.BlockingNumber) | Flight: @Model.Flight.FlightNumber</p>
                
                <form asp-action="ProcessReschedule" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookingId" value="@Model.Id" />

                    <div class="form-group" style="margin-bottom: 20px;">
                        <label>Active Departure</label>
                        <div class="form-control" style="opacity: 0.6;">@Model.Flight.DepartureTime.ToString("dd MMMM yyyy")</div>
                    </div>

                    <div class="form-group" style="margin-bottom: 25px;">
                        <label>Target Departure Date</label>
                        <input type="date" name="newDate" required class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                    <div style="background: var(--gold-dim); padding: 15px; border-radius: 8px; margin-bottom: 30px; border: 1px solid var(--gold-border);">
                        <p style="font-size: 11px; color: var(--gold); margin: 0;">Rescheduling updates status to 'Rescheduled'. Final fare adjusted at gate.</p>
                    </div>

                    <button type="submit" class="btn-submit">Update Itinerary</button>
                </form>
            </div>
        }
    </div>
</div>