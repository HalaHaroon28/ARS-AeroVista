@using Microsoft.AspNetCore.Identity
@inject UserManager<AeroVista.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Aviator Profile";
    var user = await UserManager.GetUserAsync(User);
}

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --navy: #0B1C2D;
        --gold: #C6A75E;
        --gold-border: rgba(198,167,94,0.2);
        --white: #ffffff;
        --glass: rgba(255, 255, 255, 0.03);
        --text-muted: #8a9eb2;
    }

    body {
        background: var(--navy);
        color: var(--white);
        font-family: 'DM Sans', sans-serif;
    }

    .profile-container {
        max-width: 800px;
        margin: 80px auto;
        padding: 40px;
        background: var(--glass);
        backdrop-filter: blur(15px);
        border: 1px solid var(--gold-border);
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }

    .profile-header {
        font-family: 'Orbitron', sans-serif;
        color: var(--gold);
        text-transform: uppercase;
        letter-spacing: 3px;
        border-bottom: 1px solid var(--gold-border);
        padding-bottom: 20px;
        margin-bottom: 40px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
    }

    .info-card {
        background: rgba(0,0,0,0.2);
        padding: 20px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.05);
        transition: 0.3s;
    }

        .info-card:hover {
            border-color: var(--gold-border);
            background: rgba(255,255,255,0.02);
        }

    .label-text {
        font-size: 10px;
        text-transform: uppercase;
        color: var(--gold);
        letter-spacing: 2px;
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
    }

    .val-text {
        font-size: 18px;
        color: #e0e0e0;
        font-weight: 400;
    }

    .full-width {
        grid-column: span 2;
    }

    .badge-certified {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 10px;
        color: #4ade80;
        background: rgba(74, 222, 128, 0.1);
        padding: 5px 12px;
        border-radius: 20px;
        margin-top: 40px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
</style>

<div class="profile-container">
    <h2 class="profile-header">
        <i class="fa-solid fa-id-card"></i>
        Aviator Profile
    </h2>

    @if (user != null)
    {
        <div class="info-grid">
            <div class="info-card">
                <span class="label-text">First Name</span>
                <div class="val-text">@user.FirstName</div>
            </div>

            <div class="info-card">
                <span class="label-text">Last Name</span>
                <div class="val-text">@user.LastName</div>
            </div>

            <div class="info-card">
                <span class="label-text">Email Address</span>
                <div class="val-text">@user.Email</div>
            </div>

            <div class="info-card">
                <span class="label-text">Gender</span>
                <div class="val-text">@user.Sex</div>
            </div>

            <div class="info-card full-width">
                <span class="label-text">Date of Birth</span>
                <div class="val-text">@user.DateOfBirth.ToString("dd MMMM yyyy")</div>
            </div>
        </div>

        <div class="badge-certified">
            <i class="fa-solid fa-shield-check"></i>
            Verified AeroVista Member
        </div>
    }
    else
    {
        <p>Please log in to view your flight credentials.</p>
    }
</div>