@model AeroVista.Models.ProfileViewModel
@{
    ViewData["Title"] = "Aviator Profile";
}

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --navy: #0B1C2D;
        --gold: #C6A75E;
        --gold-border: rgba(198,167,94,0.2);
        --white: #ffffff;
        --glass: rgba(255, 255, 255, 0.03);
        --text-muted: #8a9eb2;
    }

    body {
        background: var(--navy);
        color: var(--white);
        font-family: 'DM Sans', sans-serif;
    }

    .profile-container {
        max-width: 900px;
        margin: 60px auto;
        padding: 40px;
        background: var(--glass);
        backdrop-filter: blur(15px);
        border: 1px solid var(--gold-border);
        border-radius: 24px;
    }

    .profile-header {
        font-family: 'Orbitron', sans-serif;
        color: var(--gold);
        text-transform: uppercase;
        letter-spacing: 3px;
        border-bottom: 1px solid var(--gold-border);
        padding-bottom: 20px;
        margin-bottom: 30px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 20px;
        margin-bottom: 40px;
    }

    .info-card {
        background: rgba(0,0,0,0.2);
        padding: 15px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .label-text {
        font-size: 9px;
        text-transform: uppercase;
        color: var(--gold);
        letter-spacing: 2px;
        font-weight: 700;
        margin-bottom: 5px;
        display: block;
    }

    .val-text {
        font-size: 16px;
        color: #e0e0e0;
    }

    .skymiles-banner {
        background: linear-gradient(90deg, var(--gold-dim), transparent);
        border-left: 3px solid var(--gold);
        padding: 20px;
        margin-bottom: 40px;
        border-radius: 0 12px 12px 0;
    }

    .form-section {
        border-top: 1px solid var(--gold-border);
        padding-top: 30px;
        margin-top: 30px;
    }

    .input-group {
        margin-bottom: 20px;
    }
    
        .input-group label {
            display: block;
            font-family: 'Orbitron';
            font-size: 10px;
            color: var(--gold);
            margin-bottom: 8px;
        }

    .form-control-av {
        width: 100%;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--gold-border);
        padding: 12px;
        color: white;
        border-radius: 8px;
    }

    .btn-update {
        background: var(--gold);
        color: var(--navy);
        font-family: 'Orbitron';
        font-weight: 700;
        border: none;
        padding: 15px 30px;
        border-radius: 8px;
        cursor: pointer;
        width: 100%;
        margin-top: 20px;
    }

    .miles-note {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 8px;
        font-style: italic;
    }
</style>

<div class="profile-container">
    <h2 class="profile-header">Aviator Credentials</h2>

    <div class="info-grid">
        <div class="info-card">
            <span class="label-text">First Name</span>
            <div class="val-text">@Model.FirstName</div>
        </div>
        <div class="info-card">
            <span class="label-text">Last Name</span>
            <div class="val-text">@Model.LastName</div>
        </div>
        <div class="info-card">
            <span class="label-text">Sex</span>
            <div class="val-text">@Model.Sex</div>
        </div>
        <div class="info-card" style="grid-column: span 3;">
            <span class="label-text">Date of Birth</span>
            <div class="val-text">@Model.DateOfBirth.ToString("dd MMMM yyyy")</div>
        </div>
    </div>

    <div class="skymiles-banner">
        <span class="label-text">SkyMiles Balance</span>
        <div class="val-text" style="font-size: 28px; font-family: 'Orbitron'; color: var(--gold);">@Model.SkyMiles.ToString("N0") <span style="font-size: 14px;">PTS</span></div>
        <p class="miles-note">*SkyMiles will only be calculated once the user has actually flown.</p>
    </div>

    <div class="form-section">
        <h3 class="profile-header" style="font-size: 16px; border:none;">Manage Flight Information</h3>
        <form asp-action="UpdateProfile" method="post">
            @Html.AntiForgeryToken()
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="input-group">
                    <label>Email Address</label>
                    <input asp-for="NewEmail" class="form-control-av" />
                </div>
                <div class="input-group">
                    <label>Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control-av" />
                </div>
            </div>

            <div class="input-group">
                <label>Residential Address</label>
                <input asp-for="Address" class="form-control-av" />
            </div>

            <div class="input-group">
                <label>Preferred Card Number</label>
                <input asp-for="PreferredCardNumber" class="form-control-av" placeholder="XXXX XXXX XXXX XXXX" />
            </div>

            <div class="input-group" style="background: rgba(198,167,94,0.05); padding: 20px; border-radius: 12px;">
                <label>Authorize Changes (Enter Password)</label>
                <input asp-for="ConfirmPassword" class="form-control-av" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <button type="submit" class="btn-update">Update Aviator Records</button>
        </form>
    </div>
</div>