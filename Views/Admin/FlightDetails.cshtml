@model AeroVista.Models.Flights

@{
    ViewData["Title"] = "Flight Details";
}

<style>
    .page-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    .btn-back {
        background: transparent;
        color: var(--navy);
        border: 1px solid var(--gold-border);
        padding: 12px 25px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-back:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

    /* Details Container */
    .details-container {
        background: white;
        border-radius: 12px;
        padding: 30px;
        border: 1px solid rgba(198,167,94,0.1);
        max-width: 800px;
        margin: 0 auto;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }

    /* Route Header */
    .route-header {
        text-align: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(198,167,94,0.1);
    }

    .route-cities {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        margin-bottom: 15px;
    }

    .city-display {
        text-align: center;
    }

    .city-code {
        font-family: 'Orbitron', sans-serif;
        font-size: 32px;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 5px;
    }

    .city-name {
        font-size: 14px;
        color: var(--muted);
    }

    .route-arrow-large {
        color: var(--gold);
        font-size: 24px;
    }

    .flight-info-badges {
        display: flex;
        justify-content: center;
        gap: 10px;
    }

    .info-badge {
        display: inline-block;
        padding: 6px 14px;
        background: var(--gold-dim);
        color: var(--gold);
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .detail-card {
        background: var(--off-white);
        border-radius: 8px;
        padding: 20px;
    }

        .detail-card.full-width {
            grid-column: span 2;
        }

    .detail-card-title {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 600;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .time-value {
        font-weight: 700;
        color: var(--navy);
        font-size: 18px;
    }

    .date-subtext {
        font-size: 13px;
        color: var(--muted);
        margin-top: 4px;
    }

    .price-display {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--gold);
    }

    /* Seat Inventory Design */
    .inventory-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
    }

    .inventory-item {
        background: white;
        padding: 15px;
        border-radius: 8px;
        border: 1px solid var(--gold-border);
        text-align: center;
    }

    .inventory-label {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 5px;
        display: block;
    }

    .inventory-count {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--navy);
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid rgba(198,167,94,0.1);
    }

    .btn-edit {
        background: var(--gold);
        color: var(--navy);
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.3s;
    }

        .btn-edit:hover {
            background: var(--navy);
            color: var(--gold);
            transform: translateY(-2px);
        }

    .btn-delete-outline {
        background: transparent;
        color: #ef4444;
        border: 1px solid #ef4444;
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.3s;
    }

        .btn-delete-outline:hover {
            background: #ef4444;
            color: white;
            transform: translateY(-2px);
        }

    @@media (max-width: 768px) {
        .details-grid {
            grid-template-columns: 1fr;
        }

        .detail-card.full-width {
            grid-column: span 1;
        }

        .inventory-grid {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-direction: column;
        }
    }
</style>

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">
            Flight <span>Details</span>
        </h1>
        <a asp-action="Flights" asp-controller="Admin" class="btn-back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to List
        </a>
    </div>

    <div class="details-container">
        <div class="route-header">
            <div class="route-cities">
                <div class="city-display">
                    <div class="city-code">@Model.FromCity?.AirportCode</div>
                    <div class="city-name">@Model.FromCity?.CityName</div>
                </div>
                <div class="route-arrow-large">→</div>
                <div class="city-display">
                    <div class="city-code">@Model.ToCity?.AirportCode</div>
                    <div class="city-name">@Model.ToCity?.CityName</div>
                </div>
            </div>
            <div class="flight-info-badges">
                <span class="info-badge">ID: #@Model.Id</span>
                <span class="info-badge">Flight: @Model.FlightNumber</span>
            </div>
        </div>

        <div class="details-grid">
            <div class="detail-card">
                <div class="detail-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.7 5.2c.3.4.8.5 1.3.3l.5-.3c.4-.2.6-.6.5-1.1z" />
                    </svg>
                    Departure
                </div>
                <div class="time-value">@Model.DepartureTime.ToString("HH:mm")</div>
                <div class="date-subtext">@Model.DepartureTime.ToString("ddd, dd MMM yyyy")</div>
            </div>

            <div class="detail-card">
                <div class="detail-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M21 18L3 18M13 4l3.5 3.5c1.5 1.5 2 3.5 1.5 4.5-.5 1-2.5.5-3.5-1L11 8 13 4zM3 16.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 22l11-11c.5-.5.5-1.3 0-1.8l-1.4-1.4c-.5-.5-1.3-.5-1.8 0L9 15l-6 1.2z" />
                    </svg>
                    Arrival
                </div>
                <div class="time-value">@Model.ArrivalTime.ToString("HH:mm")</div>
                <div class="date-subtext">@Model.ArrivalTime.ToString("ddd, dd MMM yyyy")</div>
            </div>

            <div class="detail-card">
                <div class="detail-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                    </svg>
                    Flight Duration
                </div>
                @{
                    var duration = Model.ArrivalTime - Model.DepartureTime;
                    var hours = (int)duration.TotalHours;
                    var minutes = duration.Minutes;
                }
                <div class="time-value">@hours h @minutes m</div>
            </div>

            <div class="detail-card">
                <div class="detail-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                    Base Fare
                </div>
                <div class="price-display">Rs. @Model.Price.ToString("N0")</div>
            </div>

            <div class="detail-card full-width">
                <div class="detail-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M7 6V3a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v3" />
                        <path d="M3 12h18" />
                        <path d="M4 21V11a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10" />
                        <path d="M2 13h20" />
                    </svg>
                    Seat Inventory Status
                </div>
                <div class="inventory-grid">
                    <div class="inventory-item">
                        <span class="inventory-label">Economy</span>
                        <span class="inventory-count">@Model.EconomySeats</span>
                    </div>
                    <div class="inventory-item">
                        <span class="inventory-label">Business</span>
                        <span class="inventory-count">@Model.BusinessSeats</span>
                    </div>
                    <div class="inventory-item">
                        <span class="inventory-label">First Class</span>
                        <span class="inventory-count">@Model.FirstClassSeats</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="action-buttons">
            <a asp-action="UpdateFlight" asp-controller="Admin" asp-route-id="@Model.Id" class="btn-edit">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Modify Flight
            </a>
            <a asp-action="DeleteFlight" asp-controller="Admin" asp-route-id="@Model.Id" class="btn-delete-outline" onclick="return confirm('Are you sure you want to delete this flight?');">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0h10" />
                    <line x1="10" y1="11" x2="10" y2="17" />
                    <line x1="14" y1="11" x2="14" y2="17" />
                </svg>
                Remove Flight
            </a>
        </div>
    </div>
</div>