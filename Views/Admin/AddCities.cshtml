@model AeroVista.Models.City

@{
    ViewData["Title"] = "Add City";
}

<style>
    .page-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .back-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        color: var(--navy);
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .back-btn:hover {
            border-color: var(--gold);
            background: var(--gold-dim);
            transform: translateX(-3px);
        }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    .form-card {
        background: white;
        border-radius: 16px;
        border: 1px solid rgba(198,167,94,0.1);
        padding: 30px;
        max-width: 600px;
        margin: 0 auto;
        box-shadow: 0 8px 25px rgba(0,0,0,0.02);
    }

    .form-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid rgba(198,167,94,0.1);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-title svg {
            color: var(--gold);
        }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--muted);
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        background: white;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(198,167,94,0.1);
        }

        .form-control::placeholder {
            color: #a0aec0;
            font-size: 13px;
        }

    .text-danger {
        color: #ef4444;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .btn-submit {
        background: var(--gold);
        color: var(--navy);
        border: none;
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        justify-content: center;
        margin-top: 10px;
    }

        .btn-submit:hover {
            background: var(--navy);
            color: var(--gold);
            transform: translateY(-2px);
        }

    .airport-preview {
        background: var(--gold-dim);
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        border: 1px solid rgba(198,167,94,0.2);
    }

    .preview-icon {
        width: 50px;
        height: 50px;
        background: white;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
    }

    .preview-text {
        font-size: 14px;
        color: var(--navy);
    }

        .preview-text strong {
            color: var(--gold);
            font-family: 'Orbitron', sans-serif;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-container {
            padding: 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .form-card {
            padding: 20px;
        }
    }
</style>

<div class="page-container">
    <!-- Page Header -->
    <div class="page-header">
        <a href="@Url.Action("Cities")" class="back-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to Cities
        </a>
        <h1 class="page-title">
            Add <span>New City</span>
        </h1>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        <h3 class="form-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 8v8" />
                <path d="M8 12h8" />
            </svg>
            City Information
        </h3>

        <form asp-action="AddCities">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="CityName" class="form-label">City Name</label>
                    <input asp-for="CityName" class="form-control" placeholder="e.g., New York" />
                    <span asp-validation-for="CityName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AirportCode" class="form-label">Airport Code</label>
                    <input asp-for="AirportCode" class="form-control" placeholder="e.g., JFK" maxlength="3" style="text-transform: uppercase;" />
                    <span asp-validation-for="AirportCode" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Country" class="form-label">Country</label>
                <input asp-for="Country" class="form-control" placeholder="e.g., United States" />
                <span asp-validation-for="Country" class="text-danger"></span>
            </div>

            <!-- Live Preview (Optional) -->
            <div class="airport-preview" id="preview">
                <div class="preview-icon">
                    ✈️
                </div>
                <div class="preview-text">
                    <span id="previewCity">City</span> (<strong id="previewCode">CODE</strong>),
                    <span id="previewCountry">Country</span>
                </div>
            </div>

            <button type="submit" class="btn-submit">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 14.66V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h5.34" />
                    <polygon points="18 2 22 6 12 16 8 16 8 12 18 2" />
                </svg>
                Create City
            </button>
        </form>
    </div>
</div>

<script>
    // Live preview functionality
    document.getElementById('CityName').addEventListener('input', function() {
        document.getElementById('previewCity').textContent = this.value || 'City';
    });

    document.getElementById('AirportCode').addEventListener('input', function() {
        this.value = this.value.toUpperCase();
        document.getElementById('previewCode').textContent = this.value || 'CODE';
    });

    document.getElementById('Country').addEventListener('input', function() {
        document.getElementById('previewCountry').textContent = this.value || 'Country';
    });
</script>