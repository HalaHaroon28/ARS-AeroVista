            // Status filter
            let matchesStatus = statusFilter === '' || status.includes(statusFilter);

            // Class filter
            let matchesClass = classFilter === '' || travelClass.includes(classFilter);

            // Date filter (simplified)
            let matchesDate = true;
            if (dateFrom && dateTo) {
