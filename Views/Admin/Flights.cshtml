@model IEnumerable<AeroVista.Models.Flights>

@{
    ViewData["Title"] = "Flights Management";
}

<style>
    .flight-type-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 12px;
        font-size: 10px;
        font-weight: 600;
        margin-left: 8px;
    }
    
    .direct-flight {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
    }
    
    .connecting-flight {
        background: rgba(198, 167, 94, 0.1);
        color: var(--gold);
    }
    
    .stopover-info {
        font-size: 11px;
        color: var(--muted);
        margin-top: 4px;
    }

    .page-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    .btn-create {
        background: var(--gold);
        color: var(--navy);
        border: none;
        padding: 12px 25px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-create:hover {
            background: var(--navy);
            color: var(--gold);
            transform: translateY(-2px);
        }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        border: 1px solid rgba(198,167,94,0.1);
        transition: all 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            border-color: var(--gold-border);
            box-shadow: 0 8px 25px rgba(198,167,94,0.15);
        }

    .stat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .stat-title {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 500;
    }

    .stat-icon {
        width: 40px;
        height: 40px;
        background: var(--gold-dim);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
    }

    .stat-value {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

    .stat-trend {
        font-size: 12px;
        color: #10b981;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Search and Filter */
    .search-section {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid rgba(198,167,94,0.1);
        margin-bottom: 25px;
    }

    .search-box {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .search-input {
        flex: 1;
        padding: 12px 15px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        min-width: 250px;
    }

        .search-input:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(198,167,94,0.1);
        }

    .filter-select {
        padding: 12px 15px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        font-size: 14px;
        color: var(--navy);
        background: white;
        cursor: pointer;
    }

    .date-range {
        display: flex;
        gap: 10px;
        align-items: center;
        background: white;
        padding: 5px 10px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
    }

    .date-input {
        padding: 8px;
        border: none;
        font-size: 14px;
    }

        .date-input:focus {
            outline: none;
        }

    /* Flights Table */
    .table-section {
        background: white;
        border-radius: 12px;
        padding: 25px;
        border: 1px solid rgba(198,167,94,0.1);
        overflow-x: auto;
    }

    .flights-table {
        width: 100%;
        border-collapse: collapse;
    }

        .flights-table th {
            text-align: left;
            padding: 15px 12px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            font-weight: 600;
            border-bottom: 2px solid rgba(198,167,94,0.2);
        }

        .flights-table td {
            padding: 15px 12px;
            font-size: 14px;
            color: var(--navy);
            border-bottom: 1px solid rgba(198,167,94,0.05);
            vertical-align: middle;
        }

        .flights-table tr:hover td {
            background: rgba(198,167,94,0.02);
        }

    /* Route Badge */
    .route-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        background: var(--gold-dim);
        color: var(--gold);
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .route-arrow {
        color: var(--gold);
        opacity: 0.5;
    }

    /* Time Display */
    .time-cell {
        display: flex;
        flex-direction: column;
    }

    .time-main {
        font-weight: 600;
        color: var(--navy);
    }

    .time-sub {
        font-size: 11px;
        color: var(--muted);
    }

    /* Price Display */
    .price-cell {
        font-family: 'Orbitron', sans-serif;
        font-weight: 600;
        color: var(--gold);
    }

    /* Seats Available */
    .seats-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
    }

    .seats-high {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .seats-medium {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
    }

    .seats-low {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .action-btn {
        padding: 6px 10px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 6px;
        color: var(--navy);
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        background: white;
    }

        .action-btn:hover {
            border-color: var(--gold);
            background: var(--gold-dim);
            color: var(--gold);
            transform: translateY(-2px);
        }

        .action-btn.edit:hover {
            border-color: var(--gold);
            background: var(--gold-dim);
            color: var(--gold);
        }

        .action-btn.details:hover {
            border-color: #3b82f6;
            background: rgba(59, 130, 246, 0.1);
            color: #3b82f6;
        }

        .action-btn.delete:hover {
            border-color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

    /* Status Indicator */
    .status-indicator {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 6px;
    }

    .status-active {
        background: #10b981;
        box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2);
    }

    .status-inactive {
        background: #ef4444;
        box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.2);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: var(--muted);
    }

        .empty-state svg {
            width: 60px;
            height: 60px;
            color: var(--gold-dim);
            margin-bottom: 15px;
        }

        .empty-state h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 18px;
            color: var(--navy);
            margin-bottom: 10px;
        }

    /* Pagination */
    .pagination {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        margin-top: 20px;
    }

    .page-item {
        padding: 8px 12px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 6px;
        color: var(--navy);
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .page-item:hover,
        .page-item.active {
            background: var(--gold);
            border-color: var(--gold);
            color: var(--navy);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-container {
            padding: 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .search-box {
            flex-direction: column;
            align-items: stretch;
        }

        .date-range {
            flex-direction: column;
            align-items: stretch;
        }

        .action-buttons {
            flex-direction: column;
        }
    }
</style>

<div class="page-container">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">
            Flights <span>Management</span>
        </h1>
        <a asp-action="AddFlight" class="btn-create">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="16" />
                <line x1="8" y1="12" x2="16" y2="12" />
            </svg>
            Add New Flight
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Total Flights</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8 10a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">@(Model.Count())</div>
            <div class="stat-trend">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
                Active Routes
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Total Seats</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="8" r="4" />
                        <path d="M5.5 20v-4a6.5 6.5 0 0 1 13 0v4" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">@(Model.Any() ? Model.Sum(f => f.SeatsAvailable) : 0)</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Avg. Price</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">$@(Model.Any() ? Model.Average(f => f.Price).ToString("F0") : "0")</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Routes</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="2" y1="12" x2="22" y2="12" />
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">@Model.Select(f => f.FromCityId + "-" + f.ToCityId).Distinct().Count()</div>
        </div>
    </div>

    <!-- Search Section -->
    <div class="search-section">
        <div class="search-box">
            <input type="text" class="search-input" id="searchInput" placeholder="Search by route, city, or airport code...">
            <div class="date-range">
                <input type="date" class="date-input" id="dateFrom" placeholder="From Date">
                <span style="color: var(--muted);">to</span>
                <input type="date" class="date-input" id="dateTo" placeholder="To Date">
            </div>
            <select class="filter-select" id="priceFilter">
                <option value="">All Prices</option>
                <option value="0-500">Under $500</option>
                <option value="500-1000">$500 - $1000</option>
                <option value="1000+">$1000+</option>
            </select>
        </div>
    </div>

    <!-- Flights Table -->
    <div class="table-section">
        <table class="flights-table" id="flightsTable">
            <thead>
                <tr>
                    <th>Route</th>
                    <th>Departure</th>
                    <th>Arrival</th>
                    <th>Price</th>
                    <th>Seats</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var seatsClass = item.SeatsAvailable > 50 ? "seats-high" : (item.SeatsAvailable > 20 ? "seats-medium" : "seats-low");
                    var seatsText = item.SeatsAvailable > 50 ? "Available" : (item.SeatsAvailable > 20 ? "Limited" : "Critical");

                    <tr>
                        <td>
                            <div class="route-badge">
                                <span>@item.FromCity?.AirportCode</span>
                                <span class="route-arrow">→</span>
                                <span>@item.ToCity?.AirportCode</span>
                            </div>
                        </td>
                        <td>
                            <div class="time-cell">
                                <span class="time-main">@item.DepartureTime.ToString("HH:mm")</span>
                                <span class="time-sub">@item.DepartureTime.ToString("dd MMM yyyy")</span>
                            </div>
                        </td>
                        <td>
                            <div class="time-cell">
                                <span class="time-main">@item.ArrivalTime.ToString("HH:mm")</span>
                                <span class="time-sub">@item.ArrivalTime.ToString("dd MMM yyyy")</span>
                            </div>
                        </td>
                        <td>
                            <span class="price-cell">$@item.Price.ToString("N0")</span>
                        </td>
                        <td>
                            <span class="seats-badge @seatsClass">
                                <span class="status-indicator @(item.SeatsAvailable > 0 ? "status-active" : "status-inactive")"></span>
                                @item.SeatsAvailable (@seatsText)
                            </span>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="EditFlight" asp-route-id="@item.Id" class="action-btn edit" title="Edit Flight">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z" />
                                    </svg>
                                    Edit
                                </a>
                                <a asp-action="FlightDetails" asp-route-id="@item.Id" class="action-btn details" title="View Details">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="12" y1="16" x2="12" y2="12" />
                                        <circle cx="12" cy="8" r="1" fill="currentColor" />
                                    </svg>
                                    Details
                                </a>
                                <a asp-action="DeleteFlight" asp-route-id="@item.Id" class="action-btn delete" onclick="return confirm('Are you sure you want to delete this flight?')" title="Delete Flight">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0h10" />
                                    </svg>
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
                <h3>No Flights Found</h3>
                <p style="color: var(--muted);">Get started by adding your first flight.</p>
                <a asp-action="AddFlight" class="btn-create" style="display: inline-flex; margin-top: 15px;">
                    Add New Flight
                </a>
            </div>
        }
    </div>

    <!-- Pagination (if needed) -->
    @if (Model.Count() > 10)
    {
        <div class="pagination">
            <a href="#" class="page-item">←</a>
            <a href="#" class="page-item active">1</a>
            <a href="#" class="page-item">2</a>
            <a href="#" class="page-item">3</a>
            <a href="#" class="page-item">→</a>
        </div>
    }
</div>

<script>
    // Search functionality
    document.getElementById('searchInput')?.addEventListener('keyup', function() {
        filterTable();
    });

    document.getElementById('priceFilter')?.addEventListener('change', function() {
        filterTable();
    });

    document.getElementById('dateFrom')?.addEventListener('change', function() {
        filterTable();
    });

    document.getElementById('dateTo')?.addEventListener('change', function() {
        filterTable();
    });

    function filterTable() {
        let searchText = document.getElementById('searchInput')?.value.toLowerCase() || '';
        let priceFilter = document.getElementById('priceFilter')?.value || '';
        let dateFrom = document.getElementById('dateFrom')?.value;
        let dateTo = document.getElementById('dateTo')?.value;

        let tableRows = document.querySelectorAll('#flightsTable tbody tr');

        tableRows.forEach(row => {
            let route = row.cells[0]?.textContent.toLowerCase() || '';
            let price = parseFloat(row.cells[3]?.textContent.replace('$', '').replace(',', '') || '0');
            let departureTime = row.cells[1]?.querySelector('.time-main')?.textContent || '';
            let departureDate = row.cells[1]?.querySelector('.time-sub')?.textContent || '';

            // Search filter
            let matchesSearch = route.includes(searchText);

            // Price filter
            let matchesPrice = true;
            if (priceFilter) {
                if (priceFilter === '0-500') matchesPrice = price < 500;
                else if (priceFilter === '500-1000') matchesPrice = price >= 500 && price <= 1000;
                else if (priceFilter === '1000+') matchesPrice = price > 1000;
            }

            // Date filter (simplified - you'd want to parse dates properly)
            let matchesDate = true;
            if (dateFrom && dateTo) {
                // Add proper date comparison logic here
            }

            if (matchesSearch && matchesPrice && matchesDate) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>