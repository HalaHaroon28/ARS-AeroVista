@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    /* Dashboard Specific Styles */
    .dashboard-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    /* Welcome Section */
    .welcome-section {
        margin-bottom: 30px;
    }

    .welcome-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 5px;
    }

        .welcome-title span {
            color: var(--gold);
        }

    .welcome-date {
        color: var(--muted);
        font-size: 14px;
        letter-spacing: 0.5px;
    }

    /* Stats Cards Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        border: 1px solid rgba(198,167,94,0.1);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: -30px;
            right: -30px;
            width: 120px;
            height: 120px;
            background: radial-gradient(circle, rgba(198,167,94,0.05) 0%, transparent 70%);
            border-radius: 50%;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            border-color: var(--gold-border);
            box-shadow: 0 8px 25px rgba(198,167,94,0.15);
        }

    .stat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .stat-title {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 500;
    }

    .stat-icon {
        width: 40px;
        height: 40px;
        background: var(--gold-dim);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
    }

    .stat-value {
        font-family: 'Orbitron', sans-serif;
        font-size: 32px;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 5px;
    }

    .stat-change {
        font-size: 12px;
        color: #10b981;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .stat-change.negative {
            color: #ef4444;
        }

    /* Charts Row */
    .charts-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }

    .chart-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid rgba(198,167,94,0.1);
    }

    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(198,167,94,0.1);
    }

    .chart-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 16px;
        font-weight: 600;
        color: var(--navy);
    }

    .chart-legend {
        display: flex;
        gap: 20px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: var(--muted);
    }

    .legend-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

        .legend-dot.gold {
            background: var(--gold);
        }

        .legend-dot.navy {
            background: var(--navy);
        }

    /* Mini Bar Chart */
    .mini-bar-chart {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        height: 120px;
        margin-top: 15px;
    }

    .bar {
        flex: 1;
        background: var(--gold-dim);
        border-radius: 4px 4px 0 0;
        height: calc(100% - 30px);
        position: relative;
        transition: height 0.3s ease;
    }

        .bar::after {
            content: attr(data-value);
            position: absolute;
            top: -25px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 11px;
            color: var(--navy);
            font-weight: 600;
        }

    .bar-label {
        text-align: center;
        font-size: 11px;
        color: var(--muted);
        margin-top: 5px;
    }

    .bar.gold {
        background: var(--gold);
        opacity: 0.8;
    }

    /* Recent Activity Table */
    .recent-section {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid rgba(198,167,94,0.1);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .section-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        font-weight: 600;
        color: var(--navy);
    }

    .view-all {
        color: var(--gold);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .view-all:hover {
            text-decoration: underline;
        }

    .activity-table {
        width: 100%;
        border-collapse: collapse;
    }

        .activity-table th {
            text-align: left;
            padding: 12px 10px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            font-weight: 500;
            border-bottom: 1px solid rgba(198,167,94,0.1);
        }

        .activity-table td {
            padding: 15px 10px;
            font-size: 13px;
            color: var(--navy);
            border-bottom: 1px solid rgba(198,167,94,0.05);
        }

        .activity-table tr:hover td {
            background: rgba(198,167,94,0.02);
        }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }

        .status-badge.confirmed {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        .status-badge.pending {
            background: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
        }

        .status-badge.cancelled {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

    /* Quick Actions */
    .quick-actions {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        margin-top: 30px;
    }

    .action-btn {
        background: white;
        border: 1px solid rgba(198,167,94,0.1);
        border-radius: 10px;
        padding: 15px;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        color: var(--navy);
    }

        .action-btn:hover {
            border-color: var(--gold);
            background: var(--gold-dim);
            transform: translateY(-2px);
        }

        .action-btn svg {
            width: 24px;
            height: 24px;
            color: var(--gold);
            margin-bottom: 10px;
        }

        .action-btn span {
            display: block;
            font-size: 13px;
            font-weight: 500;
        }

    /* Responsive */
    @@media (max-width: 1200px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .charts-row {
            grid-template-columns: 1fr;
        }

        .quick-actions {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .dashboard-container {
            padding: 20px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .quick-actions {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-container">
    <!-- Welcome Section -->
    <div class="welcome-section">
        <h1 class="welcome-title">
            Welcome back, <span>Admin</span>
        </h1>
        <div class="welcome-date">
            @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Total Users</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">1,234</div>
            <div class="stat-change">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
                +12% this week
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Total Bookings</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <path d="M16 10a4 4 0 0 1-8 0" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">3,456</div>
            <div class="stat-change">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
                +8% this week
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Active Flights</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 2v4M12 22v-4M4 12H2M22 12h-2M19.07 4.93l-2.83 2.83M4.93 19.07l2.83-2.83M19.07 19.07l-2.83-2.83M4.93 4.93l2.83 2.83" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">42</div>
            <div class="stat-change">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
                +3 today
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Revenue</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">$45.6K</div>
            <div class="stat-change negative">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
                -2% this week
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="charts-row">
        <div class="chart-card">
            <div class="chart-header">
                <div class="chart-title">Weekly Bookings</div>
                <div class="chart-legend">
                    <div class="legend-item">
                        <span class="legend-dot gold"></span>
                        <span>This Week</span>
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot navy"></span>
                        <span>Last Week</span>
                    </div>
                </div>
            </div>
            <div class="mini-bar-chart">
                <div style="flex: 1; text-align: center;">
                    <div class="bar gold" data-value="45" style="height: 45px;"></div>
                    <div class="bar navy" data-value="38" style="height: 38px;"></div>
                    <div class="bar-label">Mon</div>
                </div>
                <div style="flex: 1; text-align: center;">
                    <div class="bar gold" data-value="62" style="height: 62px;"></div>
                    <div class="bar navy" data-value="55" style="height: 55px;"></div>
                    <div class="bar-label">Tue</div>
                </div>
                <div style="flex: 1; text-align: center;">
                    <div class="bar gold" data-value="78" style="height: 78px;"></div>
                    <div class="bar navy" data-value="70" style="height: 70px;"></div>
                    <div class="bar-label">Wed</div>
                </div>
                <div style="flex: 1; text-align: center;">
                    <div class="bar gold" data-value="82" style="height: 82px;"></div>
                    <div class="bar navy" data-value="75" style="height: 75px;"></div>
                    <div class="bar-label">Thu</div>
                </div>
                <div style="flex: 1; text-align: center;">
                    <div class="bar gold" data-value="71" style="height: 71px;"></div>
                    <div class="bar navy" data-value="68" style="height: 68px;"></div>
                    <div class="bar-label">Fri</div>
                </div>
                <div style="flex: 1; text-align: center;">
                    <div class="bar gold" data-value="53" style="height: 53px;"></div>
                    <div class="bar navy" data-value="49" style="height: 49px;"></div>
                    <div class="bar-label">Sat</div>
                </div>
                <div style="flex: 1; text-align: center;">
                    <div class="bar gold" data-value="48" style="height: 48px;"></div>
                    <div class="bar navy" data-value="42" style="height: 42px;"></div>
                    <div class="bar-label">Sun</div>
                </div>
            </div>
        </div>

        <div class="chart-card">
            <div class="chart-header">
                <div class="chart-title">Popular Destinations</div>
            </div>
            <div style="margin-top: 15px;">
                <div style="margin-bottom: 15px;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                        <span style="font-size: 13px; color: var(--navy);">New York</span>
                        <span style="font-size: 12px; color: var(--gold);">234 bookings</span>
                    </div>
                    <div style="height: 6px; background: var(--gold-dim); border-radius: 3px;">
                        <div style="width: 85%; height: 100%; background: var(--gold); border-radius: 3px;"></div>
                    </div>
                </div>
                <div style="margin-bottom: 15px;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                        <span style="font-size: 13px; color: var(--navy);">London</span>
                        <span style="font-size: 12px; color: var(--gold);">198 bookings</span>
                    </div>
                    <div style="height: 6px; background: var(--gold-dim); border-radius: 3px;">
                        <div style="width: 72%; height: 100%; background: var(--gold); border-radius: 3px;"></div>
                    </div>
                </div>
                <div style="margin-bottom: 15px;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                        <span style="font-size: 13px; color: var(--navy);">Dubai</span>
                        <span style="font-size: 12px; color: var(--gold);">167 bookings</span>
                    </div>
                    <div style="height: 6px; background: var(--gold-dim); border-radius: 3px;">
                        <div style="width: 61%; height: 100%; background: var(--gold); border-radius: 3px;"></div>
                    </div>
                </div>
                <div style="margin-bottom: 15px;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                        <span style="font-size: 13px; color: var(--navy);">Tokyo</span>
                        <span style="font-size: 12px; color: var(--gold);">145 bookings</span>
                    </div>
                    <div style="height: 6px; background: var(--gold-dim); border-radius: 3px;">
                        <div style="width: 53%; height: 100%; background: var(--gold); border-radius: 3px;"></div>
                    </div>
                </div>
                <div>
                    <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                        <span style="font-size: 13px; color: var(--navy);">Paris</span>
                        <span style="font-size: 12px; color: var(--gold);">112 bookings</span>
                    </div>
                    <div style="height: 6px; background: var(--gold-dim); border-radius: 3px;">
                        <div style="width: 41%; height: 100%; background: var(--gold); border-radius: 3px;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Bookings -->
    <div class="recent-section">
        <div class="section-header">
            <div class="section-title">Recent Bookings</div>
            <a href="#" class="view-all">View All →</a>
        </div>

        <table class="activity-table">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Passenger</th>
