@model AeroVista.Models.Flights

@{
    ViewData["Title"] = "Update Flight";
}

<style>
    .page-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    .btn-back {
        background: transparent;
        color: var(--navy);
        border: 1px solid var(--gold-border);
        padding: 12px 25px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-back:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

    .form-container {
        background: white;
        border-radius: 12px;
        padding: 30px;
        border: 1px solid rgba(198,167,94,0.1);
        max-width: 800px;
        margin: 0 auto;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group.full-width {
            grid-column: span 2;
        }

    .form-label {
        display: block;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 500;
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 14px 15px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        font-size: 14px;
        color: var(--navy);
        transition: all 0.3s ease;
        background: white;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(198,167,94,0.1);
        }

    .validation-message {
        font-size: 11px;
        color: #ef4444;
        margin-top: 5px;
        display: block;
    }

    /* Seat Classification Grid */
    .seat-distribution {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        background: #fcfbf8;
        padding: 20px;
        border-radius: 10px;
        border: 1px dashed var(--gold-border);
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid rgba(198,167,94,0.1);
    }

    .btn-save {
        background: var(--gold);
        color: var(--navy);
        border: none;
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex: 1;
        justify-content: center;
    }

        .btn-save:hover {
            background: var(--navy);
            color: var(--gold);
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: transparent;
        color: var(--muted);
        border: 1px solid rgba(198,167,94,0.2);
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

    /* Alert styles */
    .alert-danger {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        border-left: 4px solid #ef4444;
    }

        .alert-danger ul {
            margin: 10px 0 0 20px;
            padding: 0;
        }

    .alert-success {
        background: rgba(34, 197, 94, 0.1);
        color: #16a34a;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        border-left: 4px solid #16a34a;
    }

    @@media (max-width: 768px) {
        .form-grid, .seat-distribution {
            grid-template-columns: 1fr;
        }

        .form-group.full-width {
            grid-column: span 1;
        }
    }
</style>

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Update <span>Flight</span></h1>
        <a asp-action="Flights" asp-controller="Admin" class="btn-back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to List
        </a>
    </div>

    <div class="form-container">
        <!-- Display Success Message -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- Display Validation Errors -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-danger">
                <strong>Please fix the following errors:</strong>
                <ul>
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        foreach (var error in modelState.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <form asp-action="UpdateFlight" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-message"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-grid">
                <!-- Flight Number Field - IMPORTANT: Add this if missing -->
                <div class="form-group full-width">
                    <label asp-for="FlightNumber" class="form-label">Flight Number</label>
                    <input asp-for="FlightNumber" class="form-control" required />
                    <span asp-validation-for="FlightNumber" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="FromCityId" class="form-label">Origin</label>
                    <select asp-for="FromCityId" class="form-control" asp-items="ViewBag.FromCityId" required>
                        <option value="">-- Select Origin City --</option>
                    </select>
                    <span asp-validation-for="FromCityId" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ToCityId" class="form-label">Destination</label>
                    <select asp-for="ToCityId" class="form-control" asp-items="ViewBag.ToCityId" required>
                        <option value="">-- Select Destination City --</option>
                    </select>
                    <span asp-validation-for="ToCityId" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DepartureTime" class="form-label">Departure</label>
                    <input asp-for="DepartureTime" class="form-control" type="datetime-local"
                           value="@(Model.DepartureTime.ToString("yyyy-MM-ddTHH:mm"))" required />
                    <span asp-validation-for="DepartureTime" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ArrivalTime" class="form-label">Arrival</label>
                    <input asp-for="ArrivalTime" class="form-control" type="datetime-local"
                           value="@(Model.ArrivalTime.ToString("yyyy-MM-ddTHH:mm"))" required />
                    <span asp-validation-for="ArrivalTime" class="validation-message"></span>
                </div>

                <div class="form-group full-width">
                    <label asp-for="Price" class="form-label">Base Price (Rs.)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" min="0"
                           value="@Model.Price.ToString("0.00")" required />
                    <span asp-validation-for="Price" class="validation-message"></span>
                </div>

                @* SEAT CLASSIFICATION SECTION *@
                <div class="form-group full-width">
                    <label class="form-label">Inventory Management (Seats Available)</label>
                    <div class="seat-distribution">
                        <div>
                            <label asp-for="EconomySeats" class="form-label" style="font-size:10px;">Economy</label>
                            <input asp-for="EconomySeats" class="form-control" type="number" min="0" required />
                            <span asp-validation-for="EconomySeats" class="validation-message"></span>
                        </div>
                        <div>
                            <label asp-for="BusinessSeats" class="form-label" style="font-size:10px;">Business</label>
                            <input asp-for="BusinessSeats" class="form-control" type="number" min="0" required />
                            <span asp-validation-for="BusinessSeats" class="validation-message"></span>
                        </div>
                        <div>
                            <label asp-for="FirstClassSeats" class="form-label" style="font-size:10px;">First Class</label>
                            <input asp-for="FirstClassSeats" class="form-control" type="number" min="0" required />
                            <span asp-validation-for="FirstClassSeats" class="validation-message"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                        <polyline points="17 21 17 13 7 13 7 21" />
                        <polyline points="7 3 7 8 15 8" />
                    </svg>
                    Save Flight Configuration
                </button>
                <a asp-action="Flights" asp-controller="Admin" class="btn-cancel">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="16" />
                        <line x1="8" y1="12" x2="16" y2="12" />
                    </svg>
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');

            form.addEventListener('submit', function(e) {
                const departure = new Date(document.getElementById('DepartureTime').value);
                const arrival = new Date(document.getElementById('ArrivalTime').value);
                const fromCity = document.getElementById('FromCityId').value;
                const toCity = document.getElementById('ToCityId').value;

                // Validate cities are different
                if (fromCity === toCity) {
                    e.preventDefault();
                    alert('Origin and Destination cities cannot be the same!');
                    return;
                }

                // Validate arrival after departure
                if (arrival <= departure) {
                    e.preventDefault();
                    alert('Arrival time must be after departure time!');
                    return;
                }

                // Validate seat counts
                const economy = parseInt(document.getElementById('EconomySeats').value) || 0;
                const business = parseInt(document.getElementById('BusinessSeats').value) || 0;
                const firstClass = parseInt(document.getElementById('FirstClassSeats').value) || 0;

                if (economy < 0 || business < 0 || firstClass < 0) {
                    e.preventDefault();
                    alert('Seat counts cannot be negative!');
                    return;
                }
            });
        });
    </script>
}