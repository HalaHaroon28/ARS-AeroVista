@model AeroVista.Models.Flights

@{
    ViewData["Title"] = "Delete Flight";
}

<style>
    .page-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    .btn-back {
        background: transparent;
        color: var(--navy);
        border: 1px solid var(--gold-border);
        padding: 12px 25px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-back:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

    .delete-container {
        background: white;
        border-radius: 12px;
        padding: 30px;
        border: 1px solid rgba(198,167,94,0.1);
        max-width: 700px;
        margin: 0 auto;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }

    .warning-banner {
        background: rgba(239, 68, 68, 0.05);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
        border-left: 4px solid #ef4444;
    }

    .warning-icon {
        width: 48px;
        height: 48px;
        background: rgba(239, 68, 68, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ef4444;
    }

    .warning-text h3 {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        color: var(--navy);
        margin-bottom: 5px;
    }

    .warning-text p {
        color: var(--muted);
        font-size: 14px;
    }

    .details-card {
        background: var(--off-white);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .detail-row {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid rgba(198,167,94,0.1);
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-label {
        width: 140px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 500;
    }

    .detail-value {
        flex: 1;
        color: var(--navy);
        font-weight: 500;
    }

    .route-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: var(--gold-dim);
        color: var(--gold);
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
    }

    .price-highlight {
        font-family: 'Orbitron', sans-serif;
        font-weight: 600;
        color: var(--gold);
        font-size: 16px;
    }

    /* Updated Seat Badges */
    .seats-grid {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .seat-badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .economy-badge {
        background: rgba(106, 127, 149, 0.1);
        color: var(--muted);
    }

    .business-badge {
        background: rgba(198, 167, 94, 0.1);
        color: var(--gold);
    }

    .first-badge {
        background: rgba(11, 28, 45, 0.1);
        color: var(--navy);
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 25px;
    }

    .btn-delete {
        background: #ef4444;
        color: white;
        border: none;
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex: 1;
        justify-content: center;
    }

        .btn-delete:hover {
            background: #dc2626;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }

    .btn-cancel {
        background: transparent;
        color: var(--navy);
        border: 1px solid var(--gold-border);
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

    @@media (max-width: 768px) {
        .page-container {
            padding: 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .delete-container {
            padding: 20px;
        }

        .detail-row {
            flex-direction: column;
            gap: 5px;
        }

        .detail-label {
            width: 100%;
        }

        .form-actions {
            flex-direction: column;
        }
    }
</style>

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">
            Delete <span>Flight</span>
        </h1>
        <a asp-action="Flights" asp-controller="Admin" class="btn-back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to List
        </a>
    </div>

    <div class="delete-container">
        <div class="warning-banner">
            <div class="warning-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
            </div>
            <div class="warning-text">
                <h3>Are you absolutely sure?</h3>
                <p>This action cannot be undone. This will permanently delete flight <strong>@Model.FlightNumber</strong>.</p>
            </div>
        </div>

        <div class="details-card">
            <div class="detail-row">
                <span class="detail-label">Flight Info</span>
                <span class="detail-value">#@Model.Id | @Model.FlightNumber</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Route</span>
                <span class="detail-value">
                    <span class="route-badge">
                        <span>@Model.FromCity?.AirportCode</span>
                        <span style="opacity:0.5">→</span>
                        <span>@Model.ToCity?.AirportCode</span>
                    </span>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Departure</span>
                <span class="detail-value">@Model.DepartureTime.ToString("dd MMM yyyy, HH:mm")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Base Price</span>
                <span class="detail-value price-highlight">Rs. @Model.Price.ToString("N0")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Current Inventory</span>
                <span class="detail-value">
                    <div class="seats-grid">
                        <span class="seat-badge economy-badge">Economy: @Model.EconomySeats</span>
                        <span class="seat-badge business-badge">Business: @Model.BusinessSeats</span>
                        <span class="seat-badge first-badge">First: @Model.FirstClassSeats</span>
                    </div>
                </span>
            </div>
        </div>

        <form asp-action="DeleteFlight" asp-controller="Admin" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            @Html.AntiForgeryToken()
            <div class="form-actions">
                <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this flight?');">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6" />
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0h10" />
                        <line x1="10" y1="11" x2="10" y2="17" />
                        <line x1="14" y1="11" x2="14" y2="17" />
                    </svg>
                    Yes, Delete Flight
                </button>
                <a asp-action="Flights" asp-controller="Admin" class="btn-cancel">
                    No, Keep Flight
                </a>
            </div>
        </form>
    </div>
</div>