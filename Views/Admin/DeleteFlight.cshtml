@model AeroVista.Models.Flights

@{
    ViewData["Title"] = "Delete Flight";
}

<style>
    .page-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    .btn-back {
        background: transparent;
        color: var(--navy);
        border: 1px solid var(--gold-border);
        padding: 12px 25px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-back:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

    /* Delete Container */
    .delete-container {
        background: white;
        border-radius: 12px;
        padding: 30px;
        border: 1px solid rgba(198,167,94,0.1);
        max-width: 700px;
        margin: 0 auto;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }

    /* Warning Banner */
    .warning-banner {
        background: rgba(239, 68, 68, 0.05);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
        border-left: 4px solid #ef4444;
    }

    .warning-icon {
        width: 48px;
        height: 48px;
        background: rgba(239, 68, 68, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ef4444;
    }

    .warning-text h3 {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        color: var(--navy);
        margin-bottom: 5px;
    }

    .warning-text p {
        color: var(--muted);
        font-size: 14px;
    }

    /* Flight Details Card */
    .details-card {
        background: var(--off-white);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .detail-row {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid rgba(198,167,94,0.1);
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-label {
        width: 130px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 500;
    }

    .detail-value {
        flex: 1;
        color: var(--navy);
        font-weight: 500;
    }

    .route-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: var(--gold-dim);
        color: var(--gold);
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
    }

    .route-arrow {
        color: var(--gold);
        opacity: 0.5;
    }

    .time-display {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .time-main {
        font-weight: 600;
        color: var(--navy);
    }

    .time-sub {
        font-size: 11px;
        color: var(--muted);
    }

    .price-highlight {
        font-family: 'Orbitron', sans-serif;
        font-weight: 600;
        color: var(--gold);
        font-size: 16px;
    }

    .seats-info {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 25px;
    }

    .btn-delete {
        background: #ef4444;
        color: white;
        border: none;
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex: 1;
        justify-content: center;
    }

        .btn-delete:hover {
            background: #dc2626;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }

    .btn-cancel {
        background: transparent;
        color: var(--navy);
        border: 1px solid var(--gold-border);
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-container {
            padding: 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .delete-container {
            padding: 20px;
        }

        .warning-banner {
            flex-direction: column;
            text-align: center;
        }

        .detail-row {
            flex-direction: column;
            gap: 5px;
        }

        .detail-label {
            width: 100%;
        }

        .form-actions {
            flex-direction: column;
        }
    }
</style>

<div class="page-container">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">
            Delete <span>Flight</span>
        </h1>
        <a asp-action="Index" class="btn-back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to List
        </a>
    </div>

    <!-- Delete Container -->
    <div class="delete-container">
        <!-- Warning Banner -->
        <div class="warning-banner">
            <div class="warning-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
            </div>
            <div class="warning-text">
                <h3>Are you absolutely sure?</h3>
                <p>This action cannot be undone. This will permanently delete this flight from the system.</p>
            </div>
        </div>

        <!-- Flight Details Card -->
        <div class="details-card">
            <div class="detail-row">
                <span class="detail-label">Flight ID</span>
                <span class="detail-value">#@Model.Id</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Route</span>
                <span class="detail-value">
                    <span class="route-badge">
                        <span>@Model.FromCity?.AirportCode</span>
                        <span class="route-arrow">→</span>
                        <span>@Model.ToCity?.AirportCode</span>
                    </span>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Cities</span>
                <span class="detail-value">
                    @Model.FromCity?.CityName → @Model.ToCity?.CityName
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Departure</span>
                <span class="detail-value">
                    <div class="time-display">
                        <span class="time-main">@Model.DepartureTime.ToString("HH:mm")</span>
                        <span class="time-sub">@Model.DepartureTime.ToString("dddd, dd MMMM yyyy")</span>
                    </div>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Arrival</span>
                <span class="detail-value">
                    <div class="time-display">
                        <span class="time-main">@Model.ArrivalTime.ToString("HH:mm")</span>
                        <span class="time-sub">@Model.ArrivalTime.ToString("dddd, dd MMMM yyyy")</span>
                    </div>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Duration</span>
                <span class="detail-value">
                    @{
                        var duration = Model.ArrivalTime - Model.DepartureTime;
                        var hours = (int)duration.TotalHours;
                        var minutes = duration.Minutes;
                    }
                    @hours @($"{minutes}min")
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Price</span>
                <span class="detail-value price-highlight">$@Model.Price.ToString("N0")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Seats Available</span>
                <span class="detail-value">
                    <span class="seats-info">@Model.SeatsAvailable seats</span>
                </span>
            </div>
        </div>

        <!-- Confirmation Form -->
        <form asp-action="DeleteFlight">
            <input type="hidden" asp-for="Id" />

            <div class="form-actions">
                <button type="submit" class="btn-delete" onclick="return confirmDelete()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6" />
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0h10" />
                        <line x1="10" y1="11" x2="10" y2="17" />
                        <line x1="14" y1="11" x2="14" y2="17" />
                    </svg>
                    Yes, Delete Flight
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="16" />
                        <line x1="8" y1="12" x2="16" y2="12" />
                    </svg>
                    No, Keep Flight
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    function confirmDelete() {
        return confirm('Are you absolutely sure you want to delete this flight? This action cannot be undone.');
    }
</script>