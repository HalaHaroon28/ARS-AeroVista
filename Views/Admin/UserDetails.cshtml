@using Microsoft.AspNetCore.Identity
@model AeroVista.Models.UserDetailsViewModel

@{
    ViewData["Title"] = "User Details";
}

<style>
    .details-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .details-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .back-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        color: var(--navy);
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .back-btn:hover {
            border-color: var(--gold);
            background: var(--gold-dim);
            transform: translateX(-3px);
        }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    /* User Profile Card */
    .profile-card {
        background: white;
        border-radius: 16px;
        border: 1px solid rgba(198,167,94,0.1);
        overflow: hidden;
        margin-bottom: 25px;
    }

    .profile-cover {
        height: 120px;
        background: linear-gradient(45deg, var(--navy), var(--gold));
        position: relative;
    }

    .profile-avatar {
        position: absolute;
        bottom: -50px;
        left: 30px;
        width: 100px;
        height: 100px;
        background: white;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 4px solid white;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

        .profile-avatar span {
            font-family: 'Orbitron', sans-serif;
            font-size: 42px;
            font-weight: 600;
            color: var(--gold);
            text-transform: uppercase;
        }

    .profile-info {
        padding: 70px 30px 30px 30px;
    }

    .profile-name {
        font-size: 28px;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 5px;
    }

    .profile-email {
        color: var(--gold);
        font-size: 16px;
        margin-bottom: 20px;
    }

    .profile-badges {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .badge {
        padding: 6px 15px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

        .badge.verified {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        .badge.unverified {
            background: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
        }

        .badge.admin {
            background: rgba(198, 167, 94, 0.1);
            color: var(--gold);
        }

        .badge.user {
            background: rgba(100, 116, 139, 0.1);
            color: #64748b;
        }

        .badge.locked {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 25px;
        margin-bottom: 25px;
    }

    .detail-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        border: 1px solid rgba(198,167,94,0.1);
    }

    .card-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 16px;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid rgba(198,167,94,0.1);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .card-title svg {
            color: var(--gold);
        }

    .info-row {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid rgba(198,167,94,0.05);
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        width: 40%;
        font-size: 13px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-value {
        width: 60%;
        font-size: 14px;
        color: var(--navy);
        font-weight: 500;
    }

        .info-value.code {
            font-family: monospace;
            background: var(--off-white);
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
        }

    .status-indicator {
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

        .status-dot.active {
            background: #10b981;
            box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2);
        }

        .status-dot.inactive {
            background: #f59e0b;
            box-shadow: 0 0 0 2px rgba(245, 158, 11, 0.2);
        }

        .status-dot.locked {
            background: #ef4444;
            box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.2);
        }

    /* Roles & Claims */
    .roles-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .role-tag {
        padding: 4px 12px;
        background: var(--gold-dim);
        color: var(--gold);
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    .claim-item {
        background: var(--off-white);
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 12px;
        color: var(--navy);
        margin-bottom: 5px;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 15px;
        margin-top: 25px;
        flex-wrap: wrap;
    }

    .btn {
        padding: 12px 25px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background: var(--gold);
        color: var(--navy);
    }

        .btn-primary:hover {
            background: var(--navy);
            color: var(--gold);
            transform: translateY(-2px);
        }

    .btn-outline {
        background: transparent;
        border: 1px solid rgba(198,167,94,0.2);
        color: var(--navy);
    }

        .btn-outline:hover {
            border-color: var(--gold);
            background: var(--gold-dim);
        }

    .btn-danger {
        background: #ef4444;
        color: white;
    }

        .btn-danger:hover {
            background: #dc2626;
            transform: translateY(-2px);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .details-grid {
            grid-template-columns: 1fr;
        }

        .profile-avatar {
            left: 50%;
            transform: translateX(-50%);
        }

        .profile-info {
            text-align: center;
            padding-top: 80px;
        }

        .profile-badges {
            justify-content: center;
        }

        .info-row {
            flex-direction: column;
            gap: 5px;
        }

        .info-label, .info-value {
            width: 100%;
        }
    }
</style>

<div class="details-container">
    <!-- Header -->
    <div class="details-header">
        <a href="@Url.Action("Users")" class="back-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to Users
        </a>
        <h1 class="page-title">
            User <span>Details</span>
        </h1>
    </div>

    <!-- Profile Card -->
    <div class="profile-card">
        <div class="profile-cover"></div>
        <div class="profile-avatar">
            <span>@(Model.UserName?.Substring(0, 1).ToUpper() ?? "U")</span>
        </div>
        <div class="profile-info">
            <h2 class="profile-name">@Model.UserName</h2>
            <div class="profile-email">@Model.Email</div>
            <div class="profile-badges">
                @if (Model.EmailConfirmed)
                {
                    <span class="badge verified">✓ Email Verified</span>
                }
                else
                {
                    <span class="badge unverified">⏳ Email Unverified</span>
                }

                @if (Model.PhoneNumberConfirmed)
                {
                    <span class="badge verified">📱 Phone Verified</span>
                }

                @if (Model.TwoFactorEnabled)
                {
                    <span class="badge verified">🔐 2FA Enabled</span>
                }

                @if (Model.LockoutEnd > DateTimeOffset.Now)
                {
                    <span class="badge locked">🔒 Account Locked</span>
                }

                @foreach (var role in Model.Roles)
                {
                    <span class="badge @(role == "Admin" ? "admin" : "user")">@role</span>
                }
            </div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="details-grid">
        <!-- Account Information -->
        <div class="detail-card">
            <h3 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="4" width="20" height="16" rx="2" />
                    <line x1="8" y1="10" x2="16" y2="10" />
                </svg>
                Account Information
            </h3>

            <div class="info-row">
                <div class="info-label">User ID</div>
                <div class="info-value code">@Model.Id</div>
            </div>

            <div class="info-row">
                <div class="info-label">Username</div>
                <div class="info-value">@Model.UserName</div>
            </div>

            <div class="info-row">
                <div class="info-label">Email</div>
                <div class="info-value">@Model.Email</div>
            </div>

            <div class="info-row">
                <div class="info-label">Email Status</div>
                <div class="info-value">
                    <span class="status-indicator">
                        <span class="status-dot @(Model.EmailConfirmed ? "active" : "inactive")"></span>
                        @(Model.EmailConfirmed ? "Confirmed" : "Pending")
                    </span>
                </div>
            </div>

            <div class="info-row">
                <div class="info-label">Phone Number</div>
                <div class="info-value">@(Model.PhoneNumber ?? "Not provided")</div>
            </div>

            <div class="info-row">
                <div class="info-label">Phone Status</div>
                <div class="info-value">
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <span class="status-indicator">
                            <span class="status-dot @(Model.PhoneNumberConfirmed ? "active" : "inactive")"></span>
                            @(Model.PhoneNumberConfirmed ? "Confirmed" : "Unconfirmed")
                        </span>
                    }
                    else
                    {
                        <span>No phone number</span>
                    }
                </div>
            </div>
        </div>

        <!-- Security Information -->
        <div class="detail-card">
            <h3 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
                Security Status
            </h3>

            <div class="info-row">
                <div class="info-label">Two Factor Auth</div>
                <div class="info-value">
                    <span class="status-indicator">
                        <span class="status-dot @(Model.TwoFactorEnabled ? "active" : "inactive")"></span>
                        @(Model.TwoFactorEnabled ? "Enabled" : "Disabled")
                    </span>
                </div>
            </div>

            <div class="info-row">
                <div class="info-label">Lockout Enabled</div>
                <div class="info-value">
                    <span class="status-indicator">
                        <span class="status-dot @(Model.LockoutEnabled ? "active" : "inactive")"></span>
                        @(Model.LockoutEnabled ? "Yes" : "No")
                    </span>
                </div>
            </div>

            @if (Model.LockoutEnd != null)
            {
                <div class="info-row">
                    <div class="info-label">Lockout End</div>
                    <div class="info-value">@Model.LockoutEnd?.ToString("yyyy-MM-dd HH:mm")</div>
                </div>
            }

            <div class="info-row">
                <div class="info-label">Failed Attempts</div>
                <div class="info-value">@Model.AccessFailedCount</div>
            </div>

            <div class="info-row">
                <div class="info-label">Account Status</div>
                <div class="info-value">
                    @if (Model.LockoutEnd > DateTimeOffset.Now)
                    {
                        <span class="status-indicator">
                            <span class="status-dot locked"></span>
                            Locked
                        </span>
                    }
                    else
                    {
                        <span class="status-indicator">
                            <span class="status-dot active"></span>
                            Active
                        </span>
                    }
                </div>
            </div>
        </div>

        <!-- Roles -->
        <div class="detail-card">
            <h3 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="8" r="4" />
                    <path d="M5.5 20v-2a4 4 0 0 1 4-4h5a4 4 0 0 1 4 4v2" />
                </svg>
                User Roles
            </h3>

            <div class="info-row">
                <div class="info-label">Assigned Roles</div>
                <div class="info-value">
                    <div class="roles-list">
                        @if (Model.Roles.Any())
                        {
                            @foreach (var role in Model.Roles)
                            {
                                <span class="role-tag">@role</span>
                            }
                        }
                        else
                        {
                            <span style="color: var(--muted);">No roles assigned</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Custom Claims -->
        <div class="detail-card">
            <h3 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                </svg>
                Custom Claims
            </h3>

            <div class="info-row">
                <div class="info-label">Claims</div>
                <div class="info-value">
                    @if (Model.Claims.Any())
                    {
                        @foreach (var claim in Model.Claims)
                        {
                            <div class="claim-item">@claim</div>
                        }
                    }
                    else
                    {
                        <span style="color: var(--muted);">No custom claims</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons">
        <a href="@Url.Action("EditUser", new { id = Model.Id })" class="btn btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z" />
            </svg>
            Edit User
        </a>

        @if (Model.LockoutEnd > DateTimeOffset.Now)
        {
            <a href="@Url.Action("UnlockUser", new { id = Model.Id })" class="btn btn-outline">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                </svg>
                Unlock Account
            </a>
        }
        else
        {
            <a href="@Url.Action("LockUser", new { id = Model.Id })" class="btn btn-outline">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
                Lock Account
            </a>
        }

        <a href="@Url.Action("ResetPassword", new { id = Model.Id })" class="btn btn-outline">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 12v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h7" />
                <polyline points="15 2 21 8 15 8" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            Reset Password
        </a>

        <a href="@Url.Action("DeleteUser", new { id = Model.Id })" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this user?')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0h10" />
            </svg>
            Delete User
        </a>
    </div>
</div>