@model IEnumerable<AeroVista.Models.Feedback>

@{
    ViewData["Title"] = "Feedbacks Management";
}

<style>
    :root {
        --navy: #0B1C2D;
        --navy-mid: #112236;
        --gold: #C6A75E;
        --gold-light: #d9be80;
        --gold-dim: rgba(198,167,94,0.1);
        --gold-border: rgba(198,167,94,0.22);
        --muted: #6a7f95;
        --white: #ffffff;
        --danger: #ef4444;
        --danger-dim: rgba(239, 68, 68, 0.1);
    }

    .page-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    .btn-create {
        background: var(--gold);
        color: var(--navy);
        border: none;
        padding: 12px 25px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-create:hover {
            background: var(--navy);
            color: var(--gold);
            transform: translateY(-2px);
        }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        border: 1px solid rgba(198,167,94,0.1);
        transition: all 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            border-color: var(--gold-border);
            box-shadow: 0 8px 25px rgba(198,167,94,0.15);
        }

    .stat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .stat-title {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 500;
    }

    .stat-icon {
        width: 40px;
        height: 40px;
        background: var(--gold-dim);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
    }

    .stat-value {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

    /* Search Section */
    .search-section {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid rgba(198,167,94,0.1);
        margin-bottom: 25px;
    }

    .search-box {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .search-input {
        flex: 1;
        padding: 12px 15px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        min-width: 250px;
    }

        .search-input:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(198,167,94,0.1);
        }

    .filter-select {
        padding: 12px 15px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        font-size: 14px;
        color: var(--navy);
        background: white;
        cursor: pointer;
        min-width: 150px;
    }

    /* Table Section */
    .table-section {
        background: white;
        border-radius: 12px;
        padding: 25px;
        border: 1px solid rgba(198,167,94,0.1);
        overflow-x: auto;
    }

    .feedbacks-table {
        width: 100%;
        border-collapse: collapse;
    }

        .feedbacks-table th {
            text-align: left;
            padding: 15px 12px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            font-weight: 600;
            border-bottom: 2px solid rgba(198,167,94,0.2);
        }

        .feedbacks-table td {
            padding: 15px 12px;
            font-size: 14px;
            color: var(--navy);
            border-bottom: 1px solid rgba(198,167,94,0.05);
            vertical-align: middle;
        }

        .feedbacks-table tr:hover td {
            background: rgba(198,167,94,0.02);
        }

    /* Name Column */
    .name-cell {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .name-avatar {
        width: 32px;
        height: 32px;
        background: var(--gold-dim);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        font-weight: 600;
        font-size: 12px;
    }

    .name-details {
        display: flex;
        flex-direction: column;
    }

    .full-name {
        font-weight: 600;
        color: var(--navy);
    }

    /* Subject Badge */
    .subject-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        background: var(--gold-dim);
        color: var(--gold);
    }

    /* Message Preview */
    .message-preview {
        max-width: 250px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--muted);
        font-size: 13px;
    }

    /* Contact Info */
    .contact-info {
        display: flex;
        align-items: center;
        gap: 6px;
        color: var(--navy);
    }

    .contact-icon {
        color: var(--gold);
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 6px;
    }

    .action-btn {
        padding: 6px 8px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 6px;
        color: var(--navy);
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        background: white;
    }

        .action-btn:hover {
            border-color: var(--gold);
            background: var(--gold-dim);
            color: var(--gold);
            transform: translateY(-2px);
        }

        .action-btn.view:hover {
            border-color: #3b82f6;
            background: rgba(59, 130, 246, 0.1);
            color: #3b82f6;
        }

        .action-btn.delete:hover {
            border-color: var(--danger);
            background: var(--danger-dim);
            color: var(--danger);
        }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: var(--muted);
    }

        .empty-state svg {
            width: 60px;
            height: 60px;
            color: var(--gold-dim);
            margin-bottom: 15px;
        }

        .empty-state h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 18px;
            color: var(--navy);
            margin-bottom: 10px;
        }

    /* Responsive */
    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .page-container {
            padding: 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .search-box {
            flex-direction: column;
            align-items: stretch;
        }

        .search-input, .filter-select {
            width: 100%;
        }

        .action-buttons {
            flex-direction: column;
        }
    }
</style>

<div class="page-container">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">
            Feedbacks <span>Management</span>
        </h1>
    </div>

    <!-- Stats Cards -->
    @{
        var totalFeedbacks = Model.Count();
        var uniqueSubjects = Model.Select(f => f.Subject).Distinct().Count();
    }

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Total Feedbacks</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">@totalFeedbacks</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Topics</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="16" x2="12" y2="12" />
                        <circle cx="12" cy="8" r="1" fill="currentColor" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">@uniqueSubjects</div>
        </div>
    </div>

    <!-- Search Section -->
    <div class="search-section">
        <div class="search-box">
            <input type="text" class="search-input" id="searchInput" placeholder="Search by name, subject, or message...">
            <select class="filter-select" id="subjectFilter">
                <option value="">All Subjects</option>
                @foreach (var subject in Model.Select(f => f.Subject).Distinct())
                {
                    <option value="@subject">@subject</option>
                }
            </select>
        </div>
    </div>

    <!-- Feedbacks Table -->
    <div class="table-section">
        <table class="feedbacks-table" id="feedbacksTable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Subject</th>
                    <th>Message</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="name-cell">
                                <div class="name-avatar">
                                    @(item.FirstName?.Substring(0, 1).ToUpper() ?? "?")
                                </div>
                                <div class="name-details">
                                    <span class="full-name">@item.FirstName @item.LastName</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="contact-info">
                                <svg class="contact-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                                    <line x1="12" y1="18" x2="12" y2="18" />
                                </svg>
                                @item.ContactNo
                            </div>
                        </td>
                        <td>
                            <span class="subject-badge">@item.Subject</span>
                        </td>
                        <td>
                            <div class="message-preview" title="@item.Message">
                                @item.Message
                            </div>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Details" asp-route-id="@item.Id" class="action-btn view" title="View Details">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="12" y1="16" x2="12" y2="12" />
                                        <circle cx="12" cy="8" r="1" fill="currentColor" />
                                    </svg>
                                    View
                                </a>
                                <a asp-action="DeleteFeedback" asp-route-id="@item.Id" class="action-btn delete" title="Delete Feedback">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0h10" />
                                    </svg>
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg>
                <h3>No Feedbacks Yet</h3>
                <p style="color: var(--muted);">Be the first to share your feedback with us.</p>
            </div>
        }
    </div>
</div>

<script>
    // Search and filter functionality
    document.getElementById('searchInput')?.addEventListener('keyup', filterTable);
    document.getElementById('subjectFilter')?.addEventListener('change', filterTable);

    function filterTable() {
        let searchText = document.getElementById('searchInput')?.value.toLowerCase() || '';
        let subjectFilter = document.getElementById('subjectFilter')?.value.toLowerCase() || '';

        let tableRows = document.querySelectorAll('#feedbacksTable tbody tr');

        tableRows.forEach(row => {
            let name = row.cells[0]?.textContent.toLowerCase() || '';
            let contact = row.cells[1]?.textContent.toLowerCase() || '';
            let subject = row.cells[2]?.textContent.toLowerCase() || '';
            let message = row.cells[3]?.textContent.toLowerCase() || '';

            // Search filter
            let matchesSearch = name.includes(searchText) ||
                               contact.includes(searchText) ||
                               subject.includes(searchText) ||
                               message.includes(searchText);

            // Subject filter
            let matchesSubject = subjectFilter === '' || subject.includes(subjectFilter);

            if (matchesSearch && matchesSubject) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>