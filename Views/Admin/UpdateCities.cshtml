@model AeroVista.Models.City

@{
    ViewData["Title"] = "Update City";
}

<style>
    .page-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
    }

        .page-title span {
            color: var(--gold);
        }

    .btn-back {
        background: transparent;
        color: var(--navy);
        border: 1px solid var(--gold-border);
        padding: 12px 25px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-back:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

    /* Form Container */
    .form-container {
        background: white;
        border-radius: 12px;
        padding: 30px;
        border: 1px solid rgba(198,167,94,0.1);
        max-width: 600px;
        margin: 0 auto;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        display: block;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 500;
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 14px 15px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        font-size: 14px;
        color: var(--navy);
        transition: all 0.3s ease;
        background: white;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(198,167,94,0.1);
        }

        .form-control:read-only {
            background: var(--off-white);
            cursor: not-allowed;
        }

    .validation-message {
        font-size: 12px;
        color: #ef4444;
        margin-top: 5px;
        display: block;
    }

    /* Airport Code Badge Style for Display */
    .airport-badge-display {
        display: inline-block;
        padding: 8px 15px;
        background: var(--gold-dim);
        color: var(--gold);
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        font-family: monospace;
        letter-spacing: 1px;
        margin-top: 5px;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid rgba(198,167,94,0.1);
    }

    .btn-save {
        background: var(--gold);
        color: var(--navy);
        border: none;
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex: 1;
        justify-content: center;
    }

        .btn-save:hover {
            background: var(--navy);
            color: var(--gold);
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: transparent;
        color: var(--muted);
        border: 1px solid rgba(198,167,94,0.2);
        padding: 14px 30px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex: 1;
        justify-content: center;
    }

        .btn-cancel:hover {
            border-color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            transform: translateY(-2px);
        }

    /* Info Card */
    .info-card {
        background: var(--gold-dim);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-left: 4px solid var(--gold);
    }

    .info-icon {
        width: 40px;
        height: 40px;
        background: white;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
    }

    .info-text {
        color: var(--navy);
        font-size: 14px;
    }

        .info-text strong {
            font-family: 'Orbitron', sans-serif;
            color: var(--gold);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-container {
            padding: 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .form-container {
            padding: 20px;
        }

        .form-actions {
            flex-direction: column;
        }
    }
</style>

<div class="page-container">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">
            Update <span>City</span>
        </h1>
        <a asp-action="Cities" class="btn-back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to List
        </a>
    </div>

    <!-- Form Container -->
    <div class="form-container">
        <!-- Info Card -->
        <div class="info-card">
            <div class="info-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="16" x2="12" y2="12" />
                    <circle cx="12" cy="8" r="1" fill="currentColor" />
                </svg>
            </div>
            <div class="info-text">
                Updating city: <strong>@Model.CityName</strong> (@Model.AirportCode)
            </div>
        </div>

        <form asp-action="UpdateCities">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 20px; color: #ef4444;"></div>

            <input type="hidden" asp-for="CityId" />

            <div class="form-group">
                <label asp-for="CityName" class="form-label">City Name</label>
                <input asp-for="CityName" class="form-control" placeholder="Enter city name" />
                <span asp-validation-for="CityName" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="AirportCode" class="form-label">Airport Code</label>
                <input asp-for="AirportCode" class="form-control" placeholder="e.g., JFK, LAX, LHR"
                       oninput="this.value = this.value.toUpperCase()" />
                <span asp-validation-for="AirportCode" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="Country" class="form-label">Country</label>
                <input asp-for="Country" class="form-control" placeholder="Enter country name" />
                <span asp-validation-for="Country" class="validation-message"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                        <polyline points="17 21 17 13 7 13 7 21" />
                        <polyline points="7 3 7 8 15 8" />
                    </svg>
                    Save Changes
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Auto uppercase for airport code
        document.getElementById('AirportCode')?.addEventListener('input', function() {
            this.value = this.value.toUpperCase();
        });
    </script>
}