@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Users Management";
}

<style>
    /* Reusing dashboard styles */
    .dashboard-container {
        padding: 30px;
        background: var(--off-white);
        min-height: 100vh;
    }

    /* Welcome Section */
    .welcome-section {
        margin-bottom: 30px;
    }

    .welcome-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 5px;
    }

        .welcome-title span {
            color: var(--gold);
        }

    .welcome-date {
        color: var(--muted);
        font-size: 14px;
        letter-spacing: 0.5px;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        border: 1px solid rgba(198,167,94,0.1);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: -30px;
            right: -30px;
            width: 120px;
            height: 120px;
            background: radial-gradient(circle, rgba(198,167,94,0.05) 0%, transparent 70%);
            border-radius: 50%;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            border-color: var(--gold-border);
            box-shadow: 0 8px 25px rgba(198,167,94,0.15);
        }

    .stat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .stat-title {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 500;
    }

    .stat-icon {
        width: 40px;
        height: 40px;
        background: var(--gold-dim);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
    }

    .stat-value {
        font-family: 'Orbitron', sans-serif;
        font-size: 32px;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 5px;
    }

    .stat-change {
        font-size: 12px;
        color: #10b981;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* Users Table Section */
    .users-section {
        background: white;
        border-radius: 12px;
        padding: 25px;
        border: 1px solid rgba(198,167,94,0.1);
        margin-bottom: 30px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .section-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: var(--navy);
    }

    .search-box {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .search-input {
        padding: 10px 15px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 8px;
        width: 300px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .search-input:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(198,167,94,0.1);
        }

    .btn-primary {
        background: var(--gold);
        color: var(--navy);
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-primary:hover {
            background: var(--navy);
            color: var(--gold);
            transform: translateY(-2px);
        }

    .btn-icon {
        background: none;
        border: 1px solid rgba(198,167,94,0.2);
        padding: 8px 12px;
        border-radius: 6px;
        color: var(--navy);
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .btn-icon:hover {
            border-color: var(--gold);
            background: var(--gold-dim);
            color: var(--gold);
        }

        .btn-icon.delete:hover {
            border-color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

    /* Users Table */
    .users-table {
        width: 100%;
        border-collapse: collapse;
    }

        .users-table th {
            text-align: left;
            padding: 15px 12px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            font-weight: 600;
            border-bottom: 2px solid rgba(198,167,94,0.2);
        }

        .users-table td {
            padding: 15px 12px;
            font-size: 14px;
            color: var(--navy);
            border-bottom: 1px solid rgba(198,167,94,0.05);
            vertical-align: middle;
        }

        .users-table tr:hover td {
            background: rgba(198,167,94,0.02);
        }

    /* User Avatar */
    .user-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        background: var(--gold-dim);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
    }

    .user-details {
        display: flex;
        flex-direction: column;
    }

    .user-name {
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 2px;
    }

    .user-email {
        font-size: 12px;
        color: var(--muted);
    }

    /* Status Badge */
    .status-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

        .status-badge.confirmed {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        .status-badge.pending {
            background: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
        }

        .status-badge.locked {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 8px;
    }

    /* Filter Pills */
    .filter-pills {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .filter-pill {
        padding: 8px 16px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 20px;
        font-size: 13px;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.3s ease;
        background: white;
    }

        .filter-pill:hover,
        .filter-pill.active {
            background: var(--gold);
            border-color: var(--gold);
            color: var(--navy);
        }

    /* Pagination */
    .pagination {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        margin-top: 20px;
    }

    .page-item {
        padding: 8px 12px;
        border: 1px solid rgba(198,167,94,0.2);
        border-radius: 6px;
        color: var(--navy);
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .page-item:hover,
        .page-item.active {
            background: var(--gold);
            border-color: var(--gold);
            color: var(--navy);
        }

    /* Responsive */
    @@media (max-width: 1200px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .dashboard-container {
            padding: 20px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .section-header {
            flex-direction: column;
            align-items: stretch;
        }

        .search-input {
            width: 100%;
        }

        .users-table {
            display: block;
            overflow-x: auto;
        }

        .action-buttons {
            flex-direction: column;
        }
    }
</style>

<div class="dashboard-container">
    <!-- Welcome Section -->
    <div class="welcome-section">
        <h1 class="welcome-title">
            User <span>Management</span>
        </h1>
        <div class="welcome-date">
            @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Total Users</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-change">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
                Active Users
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">New This Month</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="8.5" cy="7" r="4" />
                        <line x1="20" y1="8" x2="20" y2="14" />
                        <line x1="23" y1="11" x2="17" y2="11" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">24</div>
            <div class="stat-change">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
                +8 this week
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Email Confirmed</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">@Model.Count(u => u.EmailConfirmed)</div>
            <div class="stat-change">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
                @((Model.Count(u => u.EmailConfirmed) * 100 / Model.Count()))% of users
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">With Phone</span>
                <div class="stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                        <line x1="12" y1="18" x2="12" y2="18" />
                    </svg>
                </div>
            </div>
            <div class="stat-value">@Model.Count(u => !string.IsNullOrEmpty(u.PhoneNumber))</div>
            <div class="stat-change">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
                Verified profiles
            </div>
        </div>
    </div>

    <!-- Users Table Section -->
    <div class="users-section">
        <div class="section-header">
            <div class="section-title">All Users</div>
            <div class="search-box">
                <input type="text" class="search-input" placeholder="Search users by email or name..." id="searchInput">
                <a href="#" class="btn-primary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    Search
                </a>
            </div>
        </div>

        <!-- Filter Pills -->
        <div class="filter-pills">
            <span class="filter-pill active">All Users</span>
            <span class="filter-pill">Email Confirmed</span>
            <span class="filter-pill">Pending Confirmation</span>
            <span class="filter-pill">With Phone</span>
            <span class="filter-pill">Admin</span>
        </div>

        <!-- Users Table -->
        <table class="users-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>User ID</th>
                    <th>Email Confirmed</th>
                    <th>Phone Number</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar">
                                    @(user.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <div class="user-details">
                                    <span class="user-name">@user.UserName</span>
                                    <span class="user-email">@user.Email</span>
                                </div>
                            </div>
                        </td>
                        <td><code style="color: var(--gold);">@user.Id.Substring(0, 8)...</code></td>
                        <td>
                            @if (user.EmailConfirmed)
                            {
                                <span style="color: #10b981;">✓ Confirmed</span>
                            }
                            else
                            {
                                <span style="color: #f59e0b;">⏳ Pending</span>
                            }
                        </td>
                        <td>@(user.PhoneNumber ?? "—")</td>
                        <td>
                            @if (user.EmailConfirmed)
                            {
                                <span class="status-badge confirmed">Active</span>
                            }
                            else
                            {
                                <span class="status-badge pending">Pending</span>
                            }
                        </td>
                        <td>
                            <div class="action-buttons">
                                
                                <a href="@Url.Action("UserDetails", "Admin", new { id = user.Id })" class="btn-icon" title="View Details">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="12" y1="16" x2="12" y2="12" />
                                        <circle cx="12" cy="8" r="1" fill="currentColor" />
                                    </svg>
                                </a>
                                <a href="@Url.Action("DeleteUser", "Admin", new { id = user.Id })"
                                   class="btn-icon delete"
                                   onclick="return confirm('Are you sure you want to delete this user? This action cannot be undone.')"
                                   title="Delete User">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0h10" />
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Pagination -->
        <div class="pagination">
            <a href="#" class="page-item">←</a>
            <a href="#" class="page-item active">1</a>
            <a href="#" class="page-item">2</a>
            <a href="#" class="page-item">3</a>
            <a href="#" class="page-item">4</a>
            <a href="#" class="page-item">5</a>
            <a href="#" class="page-item">→</a>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
        <a href="#" class="action-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="8.5" cy="7" r="4" />
                <line x1="20" y1="8" x2="20" y2="14" />
                <line x1="23" y1="11" x2="17" y2="11" />
            </svg>
            <span>Add New User</span>
        </a>
        <a href="#" class="action-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4v16h16" />
                <polyline points="20 10 12 18 8 14" />
            </svg>
            <span>Export Users</span>
        </a>
        <a href="#" class="action-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                <line x1="8" y1="21" x2="16" y2="21" />
                <line x1="12" y1="17" x2="12" y2="21" />
            </svg>
            <span>Send Bulk Email</span>
        </a>
        <a href="#" class="action-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="2" />
                <path d="M12 2a10 10 0 0 0 0 20 10 10 0 0 0 0-20z" />
                <path d="M12 6v6l4 2" />
            </svg>
            <span>Activity Log</span>
        </a>
    </div>
</div>

<script>
    // Simple search functionality
    document.getElementById('searchInput').addEventListener('keyup', function() {
        let searchText = this.value.toLowerCase();
        let tableRows = document.querySelectorAll('.users-table tbody tr');

        tableRows.forEach(row => {
            let userCell = row.querySelector('.user-info');
            if (userCell) {
                let userName = userCell.querySelector('.user-name')?.textContent.toLowerCase() || '';
                let userEmail = userCell.querySelector('.user-email')?.textContent.toLowerCase() || '';

                if (userName.includes(searchText) || userEmail.includes(searchText)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            }
        });
    });

    // Filter pills functionality
    document.querySelectorAll('.filter-pill').forEach(pill => {
        pill.addEventListener('click', function() {
            document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
            this.classList.add('active');
            // Add your filter logic here
        });
    });

        function deleteUser(userId, element) {
        if (confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
            // Create form data
            const formData = new FormData();
            formData.append('id', userId);

            // Send the request
            fetch('/Admin/DeleteUser', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: formData  // Use FormData instead of JSON
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Remove the row from table
                    const row = element.closest('tr');
                    if (row) {
                        row.remove();
                    }
                    alert(data.message);

                    // Optional: Refresh the page or update stats
                    location.reload(); // Simple solution to refresh stats
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error deleting user: ' + error);
            });
        }
    }
</script>