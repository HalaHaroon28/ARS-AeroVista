@model List<AeroVista.Models.Flights>
@{
    var search = ViewBag.SearchModel as AeroVista.Models.FlightSearchViewModel;
    var returnFlights = ViewBag.ReturnFlights as List<AeroVista.Models.Flights>;
    ViewData["Title"] = "Available Voyages";

    decimal GetFullTotalPrice(decimal basePrice, int adults, int children, string travelClass)
    {
        decimal total = (basePrice * adults) + (basePrice * 0.7m * children);
        if (travelClass == "Business") total *= 1.30m;
        else if (travelClass == "First") total *= 1.50m;
        return total;
    }
}

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --navy: #0B1C2D;
        --navy-light: #162a3d;
        --gold: #C6A75E;
        --gold-border: rgba(198,167,94,0.2);
        --text-muted: #8a9eb2;
        --white: #ffffff;
        --danger: #ff4d4d;
    }

    body { background: var(--navy); color: var(--white); font-family: 'DM Sans', sans-serif; }
    .page-background { position: fixed; inset: 0; z-index: -1; background: radial-gradient(circle at top right, #1a3350 0%, #0b1c2d 100%); }
    .results-wrapper { max-width: 1100px; margin: 60px auto; padding: 0 20px; }
    
    .section-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 1.5rem;
        letter-spacing: 2px;
        color: var(--gold);
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 15px;
        text-transform: uppercase;
    }

    .section-title::after { content: ''; height: 1px; flex: 1; background: linear-gradient(to right, var(--gold-border), transparent); }

    .flight-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid var(--gold-border);
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 20px;
        display: grid;
        grid-template-columns: 1fr 1.5fr 1fr 1.2fr;
        align-items: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .flight-card:hover {
        transform: scale(1.01);
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--gold);
    }

    .city-code { font-family: 'Orbitron', sans-serif; font-size: 28px; font-weight: 800; display: block; }
    .time-val { color: var(--text-muted); font-size: 13px; margin-top: 5px; }
    .flight-path-container { text-align: center; padding: 0 20px; }
    
    .duration-tag {
        font-family: 'Orbitron', sans-serif;
        font-size: 9px;
        color: var(--gold);
        text-transform: uppercase;
        letter-spacing: 2px;
        background: rgba(198, 167, 94, 0.1);
        padding: 4px 12px;
        border-radius: 4px;
        margin-bottom: 10px;
        display: inline-block;
    }

    .path-line { height: 1px; background: var(--gold-border); position: relative; margin-top: 15px; }
    .plane-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #112236; padding: 0 10px; color: var(--gold); font-size: 14px; }

    .price-section { border-left: 1px solid var(--gold-border); padding-left: 30px; text-align: right; }
    .price-tag { font-family: 'Orbitron', sans-serif; font-size: 22px; color: var(--white); }
    .class-tag { font-size: 10px; color: var(--gold); text-transform: uppercase; letter-spacing: 1px; font-weight: bold; display: block; margin-top: 5px; margin-bottom: 5px; }

    .availability-tag { font-size: 11px; color: var(--text-muted); margin-bottom: 15px; display: block; }

    .btn-book {
        background: var(--gold);
        color: var(--navy);
        border: none;
        padding: 12px;
        border-radius: 8px;
        font-family: 'Orbitron', sans-serif;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: 0.3s;
        width: 100%;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .btn-book:hover { background: var(--white); transform: translateY(-2px); }

    .error-toast {
        background: rgba(255, 77, 77, 0.1);
        border: 1px solid var(--danger);
        color: white;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 30px;
        font-family: 'Orbitron';
        font-size: 12px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
</style>

<div class="page-background"></div>
<div class="results-wrapper">
    @if (TempData["Error"] != null)
    {
        <div class="error-toast">
            <i class="fa-solid fa-triangle-exclamation" style="color: var(--danger)"></i>
            SYSTEM ALERT: @TempData["Error"]
        </div>
    }

    <h2 class="section-title">Outbound Voyage</h2>

    @foreach (var flight in Model)
    {
        var total = GetFullTotalPrice(flight.Price, search.Adults, search.Children, search.TravelClass);
        var daysUntilDeparture = (flight.DepartureTime - DateTime.Now).TotalDays;
        bool canBlock = daysUntilDeparture > 14;
        
        int seatsLeft = search.TravelClass switch {
            "First" => flight.FirstClassSeats,
            "Business" => flight.BusinessSeats,
            _ => flight.EconomySeats
        };

        <div class="flight-card">
            <div>
                <span class="city-code">@flight.FromCity.AirportCode</span>
                <div class="time-val">@flight.DepartureTime.ToString("HH:mm") <br /> @flight.FromCity.CityName</div>
            </div>

            <div class="flight-path-container">
                <span class="duration-tag">@flight.FlightNumber</span>
                <div class="path-line"><i class="fa-solid fa-plane plane-icon"></i></div>
                <div style="font-size: 10px; color: var(--text-muted); margin-top: 15px;">NON-STOP</div>
            </div>

            <div>
                <span class="city-code">@flight.ToCity.AirportCode</span>
                <div class="time-val">@flight.ArrivalTime.ToString("HH:mm") <br /> @flight.ToCity.CityName</div>
            </div>

            <div class="price-section">
                <div class="price-tag">Rs. @total.ToString("N0")</div>
                <span class="class-tag">@search.TravelClass Class</span>
                <span class="availability-tag">@seatsLeft Seats Remaining</span>

                <form asp-controller="Booking" asp-action="Book" method="post">
                    <input type="hidden" name="flightId" value="@flight.Id" />
                    <input type="hidden" name="adults" value="@search.Adults" />
                    <input type="hidden" name="children" value="@search.Children" />
                    <input type="hidden" name="travelClass" value="@search.TravelClass" />

                    <button type="submit" name="actionType" value="Buy" class="btn-book">Select Flight</button>

                    @if (canBlock)
                    {
                        <button type="submit" name="actionType" value="Block" class="btn-book"
                                style="margin-top:10px; background:transparent; border:1px solid var(--gold); color:var(--gold);">
                            Block Ticket
                        </button>
                    }
                    else
                    {
                        <div style="font-size: 9px; color: var(--text-muted); margin-top: 12px; text-transform: uppercase; letter-spacing: 1px;">
                            <i class="fa-solid fa-lock"></i> Blocking Restricted
                        </div>
                    }
                </form>
            </div>
        </div>
    }

    @if (search.TripType == "RoundTrip" && returnFlights != null && returnFlights.Any())
    {
        <div style="margin-top: 80px;">
            <h2 class="section-title">Return Voyage</h2>
            @foreach (var rFlight in returnFlights)
            {
                var rTotal = GetFullTotalPrice(rFlight.Price, search.Adults, search.Children, search.TravelClass);
                int rSeatsLeft = search.TravelClass switch {
                    "First" => rFlight.FirstClassSeats,
                    "Business" => rFlight.BusinessSeats,
                    _ => rFlight.EconomySeats
                };

                <div class="flight-card">
                    <div>
                        <span class="city-code">@rFlight.FromCity.AirportCode</span>
                        <div class="time-val">@rFlight.DepartureTime.ToString("HH:mm")</div>
                    </div>
                    <div class="flight-path-container">
                        <span class="duration-tag">@rFlight.FlightNumber</span>
                        <div class="path-line"><i class="fa-solid fa-plane plane-icon"></i></div>
                    </div>
                    <div>
                        <span class="city-code">@rFlight.ToCity.AirportCode</span>
                        <div class="time-val">@rFlight.ArrivalTime.ToString("HH:mm")</div>
                    </div>
                    <div class="price-section">
                        <div class="price-tag">Rs. @rTotal.ToString("N0")</div>
                        <span class="class-tag">@search.TravelClass Class</span>
                        <span class="availability-tag">@rSeatsLeft Seats Remaining</span>

                        <form asp-controller="Booking" asp-action="Book" method="post">
                            <input type="hidden" name="flightId" value="@rFlight.Id" />
                            <input type="hidden" name="adults" value="@search.Adults" />
                            <input type="hidden" name="children" value="@search.Children" />
                            <input type="hidden" name="travelClass" value="@search.TravelClass" />
                            <button type="submit" name="actionType" value="Buy" class="btn-book">Select Return</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>