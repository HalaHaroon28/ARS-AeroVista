@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
    :root {
        --navy: #0B1C2D;
        --navy-mid: #112236;
        --navy-light: #1a3350;
        --gold: #C6A75E;
        --gold-light: #d9be80;
        --gold-dim: rgba(198,167,94,0.1);
        --gold-border: rgba(198,167,94,0.2);
        --muted: #6a7f95;
        --text-light: #c8d4e0;
        --off-white: #F5F5F5;
        --white: #ffffff;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--off-white);
        font-family: 'DM Sans', sans-serif;
        overflow-x: hidden;
    }

    /* Hero Section */
    .privacy-hero {
        position: relative;
        height: 45vh;
        min-height: 380px;
        width: 100%;
        overflow: hidden;
        display: flex;
        align-items: center;
    }

    .privacy-bg {
        position: absolute;
        inset: 0;
        z-index: 1;
        background-image: url('~/images/privacy-bg.jpg');
        background-size: cover;
        background-position: center;
        filter: brightness(0.35) saturate(0.8);
    }

    .privacy-overlay {
        position: absolute;
        inset: 0;
        z-index: 2;
        background: linear-gradient(108deg, rgba(15, 40, 65, 0.95) 0%, rgba(12, 37, 62, 0.65) 55%, rgba(16, 31, 46, 0.2) 100%);
    }

    .privacy-grid {
        position: absolute;
        inset: 0;
        z-index: 3;
        background-image: linear-gradient(rgba(198,167,94,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(198,167,94,0.035) 1px, transparent 1px);
        background-size: 72px 72px;
        animation: gridDrift 22s linear infinite;
    }

    @@keyframes gridDrift {
        0% { background-position: 0 0; }
        100% { background-position: 72px 72px; }
    }

    .privacy-scan {
        position: absolute;
        inset: 0;
        z-index: 4;
        background: linear-gradient(to bottom, transparent, rgba(198,167,94,0.025) 50%, transparent);
        background-size: 100% 180px;
        animation: scanMove 9s linear infinite;
        pointer-events: none;
    }

    @@keyframes scanMove {
        0% { background-position: 0 -180px; }
        100% { background-position: 0 100vh; }
    }

    .privacy-hero-content {
        position: relative;
        z-index: 5;
        padding: 0 6vw;
        width: 100%;
        animation: heroIn 1.1s cubic-bezier(0.22,1,0.36,1) forwards;
    }

    @@keyframes heroIn {
        from { opacity: 0; transform: translateY(28px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .privacy-eyebrow {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 22px;
    }

    .privacy-eyebrow-line {
        width: 36px;
        height: 1px;
        background: var(--gold);
    }

    .privacy-eyebrow-text {
        font-family: 'Orbitron', sans-serif;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 4px;
        color: var(--gold);
        text-transform: uppercase;
    }

    .privacy-hero h1 {
        font-family: 'Orbitron', sans-serif;
        font-size: clamp(42px, 5.5vw, 64px);
        font-weight: 900;
        color: var(--white);
        line-height: 1.08;
        letter-spacing: -0.5px;
        margin-bottom: 18px;
    }

    .privacy-hero h1 .accent {
        color: var(--gold);
        display: block;
    }

    .privacy-hero-sub {
        font-size: 16px;
        font-weight: 300;
        color: var(--text-light);
        max-width: 600px;
        line-height: 1.75;
    }

    .last-updated {
        margin-top: 25px;
        font-family: 'Orbitron', sans-serif;
        font-size: 11px;
        color: var(--gold);
        letter-spacing: 1.5px;
        text-transform: uppercase;
        background: var(--gold-dim);
        border: 1px solid var(--gold-border);
        padding: 8px 18px;
        border-radius: 4px;
        display: inline-block;
    }

    /* Main Content */
    .privacy-content {
        padding: 60px 6vw;
        position: relative;
        z-index: 10;
        margin-top: -40px;
    }

    .privacy-card {
        background: var(--white);
        border-radius: 24px;
        padding: 60px;
        box-shadow: 0 32px 80px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(198,167,94,0.1);
    }

    .privacy-card::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(198,167,94,0.03), transparent 70%);
        border-radius: 50%;
    }

    .privacy-card::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(11,28,45,0.02), transparent 70%);
        border-radius: 50%;
    }

    .privacy-section {
        margin-bottom: 50px;
        position: relative;
        z-index: 1;
    }

    .privacy-section:last-child {
        margin-bottom: 0;
    }

    .privacy-section-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 25px;
    }

    .privacy-section-icon {
        width: 48px;
        height: 48px;
        background: var(--gold-dim);
        border: 1px solid var(--gold-border);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        flex-shrink: 0;
    }

    .privacy-section h2 {
        font-family: 'Orbitron', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: var(--navy);
        line-height: 1.3;
    }

    .privacy-section h3 {
        font-family: 'Orbitron', sans-serif;
        font-size: 18px;
        font-weight: 600;
        color: var(--navy);
        margin: 30px 0 15px;
    }

    .privacy-section h4 {
        font-family: 'Orbitron', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: var(--gold);
        margin: 20px 0 10px;
        letter-spacing: 0.5px;
    }

    .privacy-section p {
        font-size: 15px;
        color: #4a5f72;
        line-height: 1.8;
        margin-bottom: 15px;
    }

    .privacy-section p:last-child {
        margin-bottom: 0;
    }

    .privacy-section ul, 
    .privacy-section ol {
        margin: 15px 0 20px 25px;
        color: #4a5f72;
        line-height: 1.8;
    }

    .privacy-section li {
        margin-bottom: 8px;
        font-size: 15px;
    }

    .privacy-section li::marker {
        color: var(--gold);
    }

    .privacy-note {
        background: var(--off-white);
        border-left: 3px solid var(--gold);
        padding: 20px 25px;
        border-radius: 8px;
        margin: 25px 0;
        font-style: italic;
    }

    .privacy-note p {
        margin-bottom: 0;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        margin: 25px 0;
        font-size: 14px;
    }

    .data-table th {
        background: var(--navy);
        color: var(--white);
        font-family: 'Orbitron', sans-serif;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 12px 15px;
        text-align: left;
    }

    .data-table td {
        padding: 12px 15px;
        border-bottom: 1px solid rgba(198,167,94,0.1);
        color: #4a5f72;
    }

    .data-table tr:last-child td {
        border-bottom: none;
    }

    .data-table tr:hover td {
        background: var(--gold-dim);
    }

    .highlight-box {
        background: var(--navy);
        border: 1px solid var(--gold-border);
        border-radius: 12px;
        padding: 25px;
        color: var(--white);
        margin: 25px 0;
    }

    .highlight-box h4 {
        color: var(--gold);
        margin-top: 0;
    }

    .highlight-box p {
        color: var(--text-light);
        margin-bottom: 0;
    }

    .two-column-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin: 25px 0;
    }

    .grid-item {
        background: var(--off-white);
        padding: 20px;
        border-radius: 8px;
        border: 1px solid rgba(198,167,94,0.1);
    }

    .grid-item h4 {
        margin-top: 0;
        margin-bottom: 10px;
        color: var(--navy);
    }

    .contact-methods {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin: 30px 0 20px;
    }

    .contact-method {
        flex: 1;
        min-width: 200px;
        background: var(--white);
        border: 1px solid var(--gold-border);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .contact-method:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(198,167,94,0.15);
    }

    .contact-method-icon {
        width: 48px;
        height: 48px;
        background: var(--gold-dim);
        border: 1px solid var(--gold-border);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        color: var(--gold);
    }

    .contact-method h4 {
        font-size: 14px;
        margin-bottom: 8px;
        color: var(--navy);
    }

    .contact-method p {
        font-size: 13px;
        color: var(--muted);
        margin-bottom: 0;
    }

    .contact-method a {
        color: var(--gold);
        text-decoration: none;
        font-weight: 600;
    }

    .contact-method a:hover {
        text-decoration: underline;
    }

    .cookie-banner-preview {
        background: var(--navy-light);
        border: 1px solid var(--gold-border);
        border-radius: 12px;
        padding: 20px;
        margin: 25px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .cookie-banner-preview p {
        color: var(--text-light);
        margin-bottom: 0;
        font-size: 14px;
    }

    .cookie-buttons {
        display: flex;
        gap: 10px;
    }

    .cookie-btn {
        padding: 8px 16px;
        border-radius: 6px;
        font-family: 'Orbitron', sans-serif;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: default;
    }

    .cookie-btn.accept {
        background: var(--gold);
        color: var(--navy);
    }

    .cookie-btn.decline {
        background: transparent;
        border: 1px solid var(--gold-border);
        color: var(--text-light);
    }

    .divider {
        height: 1px;
        background: linear-gradient(to right, transparent, var(--gold-border), transparent);
        margin: 40px 0;
    }

    .back-to-top {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 50px;
        height: 50px;
        background: var(--gold);
        border: none;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        box-shadow: 0 4px 15px rgba(198,167,94,0.3);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        z-index: 100;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    .back-to-top.visible {
        opacity: 1;
        visibility: visible;
    }

    .back-to-top:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(198,167,94,0.4);
    }

    .table-of-contents {
        background: var(--off-white);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 40px;
        border: 1px solid var(--gold-border);
    }

    .table-of-contents h3 {
        font-family: 'Orbitron', sans-serif;
        font-size: 16px;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 15px;
    }

    .toc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 10px;
    }

    .toc-item {
        color: var(--navy);
        text-decoration: none;
        font-size: 14px;
        padding: 8px 12px;
        border-radius: 6px;
        transition: background 0.25s, color 0.25s;
    }

    .toc-item:hover {
        background: var(--gold-dim);
        color: var(--gold);
    }

    .jurisdiction-flags {
        display: flex;
        gap: 15px;
        margin: 20px 0;
        flex-wrap: wrap;
    }

    .jurisdiction-flag {
        padding: 8px 16px;
        background: var(--white);
        border: 1px solid var(--gold-border);
        border-radius: 30px;
        font-size: 13px;
        color: var(--navy);
    }

    .jurisdiction-flag span {
        color: var(--gold);
        font-weight: 600;
        margin-right: 5px;
    }

    @@media (max-width: 768px) {
        .privacy-card {
            padding: 30px;
        }
        
        .two-column-grid {
            grid-template-columns: 1fr;
        }
        
        .privacy-section-header {
            flex-direction: column;
            text-align: center;
            gap: 10px;
        }
        
        .data-table {
            display: block;
            overflow-x: auto;
        }
        
        .back-to-top {
            bottom: 20px;
            right: 20px;
        }
    }
</style>

<!-- Hero Section -->
<div class="privacy-hero">
    <div class="privacy-bg"></div>
    <div class="privacy-overlay"></div>
    <div class="privacy-grid"></div>
    <div class="privacy-scan"></div>
    
    <div class="privacy-hero-content">
        <div class="privacy-eyebrow">
            <div class="privacy-eyebrow-line"></div>
            <span class="privacy-eyebrow-text">Your Privacy Matters</span>
        </div>
        <h1>
            Transparency & Trust.
            <span class="accent">Our Privacy Commitment.</span>
        </h1>
        <p class="privacy-hero-sub">We believe in clear communication about how we collect, use, and protect your personal information when you fly with us.</p>
        
        <div class="last-updated">
            Last Updated: March 15, 2026
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="privacy-content">
    <div class="privacy-card">
        
        <!-- Table of Contents -->
        <div class="table-of-contents">
            <h3>Quick Navigation</h3>
            <div class="toc-grid">
                <a href="#introduction" class="toc-item">1. Introduction</a>
                <a href="#information-collection" class="toc-item">2. Information We Collect</a>
                <a href="#usage" class="toc-item">3. How We Use Information</a>
                <a href="#sharing" class="toc-item">4. Information Sharing</a>
                <a href="#cookies" class="toc-item">5. Cookies & Tracking</a>
                <a href="#data-security" class="toc-item">6. Data Security</a>
                <a href="#your-rights" class="toc-item">7. Your Rights</a>
                <a href="#international" class="toc-item">8. International Transfers</a>
                <a href="#children" class="toc-item">9. Children's Privacy</a>
                <a href="#retention" class="toc-item">10. Data Retention</a>
                <a href="#changes" class="toc-item">11. Policy Changes</a>
                <a href="#contact" class="toc-item">12. Contact Us</a>
            </div>
        </div>

        <!-- 1. Introduction -->
        <div id="introduction" class="privacy-section">
            <div class="privacy-section-header">
                <div class="privacy-section-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="16" x2="12" y2="12" />
                        <circle cx="12" cy="8" r="0.5" fill="currentColor" />
                    </svg>
                </div>
                <h2>1. Introduction</h2>
            </div>
            
            <p>Welcome to AeroVista Airlines. We are committed to protecting your privacy and handling your personal information with transparency and care. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website, use our mobile applications, book flights, or interact with our services.</p>
            
            <p>AeroVista Airlines is a global carrier operating in over 48 countries. We comply with applicable data protection laws including the General Data Protection Regulation (GDPR) in Europe, the California Consumer Privacy Act (CCPA), and other relevant privacy regulations in the jurisdictions where we operate.</p>
            
            <div class="jurisdiction-flags">
                <div class="jurisdiction-flag"><span>🌍</span> GDPR Compliant</div>
                <div class="jurisdiction-flag"><span>🇺🇸</span> CCPA Compliant</div>
                <div class="jurisdiction-flag"><span>🇬🇧</span> UK GDPR</div>
                <div class="jurisdiction-flag"><span>🇨🇦</span> PIPEDA</div>
            </div>
            
            <p>By using our services, you acknowledge the practices described in this policy. If you do not agree with our policies, please do not use our services.</p>
            
            <div class="privacy-note">
                <p><strong>✈️ Our Commitment:</strong> Your data is as important to us as your safety in the air. We handle it with the same level of care and precision that we apply to every flight operation.</p>
            </div>
        </div>

        <div class="divider"></div>

        <!-- 2. Information We Collect -->
        <div id="information-collection" class="privacy-section">
            <div class="privacy-section-header">
                <div class="privacy-section-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="2" y="4" width="20" height="16" rx="2" />
                        <line x1="8" y1="10" x2="16" y2="10" />
                        <line x1="8" y1="14" x2="12" y2="14" />
                    </svg>
                </div>
                <h2>2. Information We Collect</h2>
            </div>
            
            <p>We collect several types of information from and about users of our services, including:</p>
            
            <h3>2.1 Personal Information You Provide</h3>
            
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Examples</th>
                        <th>Purpose</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Identity Data</strong></td>
                        <td>Full name, date of birth, gender, passport/national ID number, nationality</td>
                        <td>Booking verification, security checks, immigration compliance</td>
                    </tr>
                    <tr>
                        <td><strong>Contact Data</strong></td>
                        <td>Email address, phone number, billing address, emergency contact information</td>
                        <td>Booking confirmation, flight updates, customer support</td>
                    </tr>
                    <tr>
                        <td><strong>Payment Data</strong></td>
                        <td>Credit/debit card details, billing information, frequent flyer numbers</td>
                        <td>Ticket purchases, refunds, loyalty program management</td>
                    </tr>
                    <tr>
                        <td><strong>Travel Data</strong></td>
                        <td>Flight history, seat preferences, meal preferences, special assistance requirements</td>
                        <td>Personalizing your travel experience, service improvement</td>
                    </tr>
                    <tr>
                        <td><strong>Biometric Data</strong></td>
                        <td>Facial recognition (for expedited boarding where available)</td>
                        <td>Optional identity verification, streamlining airport processes</td>
                    </tr>
                </tbody>
            </table>
            
            <h3>2.2 Information Automatically Collected</h3>
            <p>When you access our website or mobile app, we automatically collect certain information through cookies and similar technologies:</p>
            <ul>
                <li><strong>Usage Data:</strong> Pages visited, time spent, links clicked, search history</li>
                <li><strong>Device Data:</strong> IP address, browser type, operating system, device identifiers</li>
                <li><strong>Location Data:</strong> Approximate location based on IP address, precise location (with your permission for airport services)</li>
                <li><strong>Cookies:</strong> See our <a href="#cookies" style="color: var(--gold);">Cookies section</a> for detailed information</li>
            </ul>
            
            <h3>2.3 Information from Third Parties</h3>
            <p>We may receive information about you from:</p>
            <ul>
                <li><strong>Travel Partners:</strong> Travel agencies, online booking platforms, other airlines (codeshare partners)</li>
                <li><strong>Government Agencies:</strong> Customs and border protection for international travel</li>
                <li><strong>Payment Processors:</strong> Fraud detection and payment verification services</li>
                <li><strong>Social Media:</strong> When you interact with our social media accounts</li>
            </ul>
            
            <div class="highlight-box">
                <h4>✈️ Special Category Data</h4>
                <p>For certain services (like special meals or medical assistance), we may collect health information. This data is processed only with your explicit consent and is subject to enhanced protection measures under applicable laws.</p>
            </div>
        </div>

        <div class="divider"></div>

        <!-- 3. How We Use Your Information -->
        <div id="usage" class="privacy-section">
            <div class="privacy-section-header">
                <div class="privacy-section-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <circle cx="12" cy="12" r="3" />
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" />
                    </svg>
                </div>
                <h2>3. How We Use Your Information</h2>
            </div>
            
            <p>We use the information we collect for the following purposes:</p>
            
            <div class="two-column-grid">
                <div class="grid-item">
                    <h4>🎫 Booking & Reservations</h4>
                    <p>Process your flight bookings, issue tickets, manage changes/cancellations, and provide boarding passes.</p>
                </div>
                <div class="grid-item">
                    <h4>👤 Account Management</h4>
                    <p>Create and manage your AeroVista account, frequent flyer program, and preferences.</p>
                </div>
                <div class="grid-item">
                    <h4>📢 Communications</h4>
                    <p>Send booking confirmations, flight updates, service notifications, and marketing (with consent).</p>
                </div>
                <div class="grid-item">
                    <h4>🔒 Security & Safety</h4>
