<script>
    let index = 0;
    const slides = document.getElementById("slides");
    const total = slides.children.length;
    const dots = document.querySelectorAll('.dot');

    function goTo(i) {
        index = (i + total) % total;
        slides.style.transform = `translateX(-${index * 100}%)`;
        dots.forEach(d => d.classList.remove('active'));
        dots[index].classList.add('active');
    }

    dots.forEach(dot => dot.addEventListener('click', () => goTo(parseInt(dot.dataset.index))));
    setInterval(() => goTo(index + 1), 5500);

    const radios = document.querySelectorAll('input[name="tripType"]');
    const returnGroup = document.getElementById("returnDateGroup");

    radios.forEach(radio => {
        radio.addEventListener("change", function () {
            returnGroup.style.opacity = this.value === "oneway" ? "0.3" : "1";
            returnGroup.style.pointerEvents = this.value === "oneway" ? "none" : "auto";
        });
    });
</script>